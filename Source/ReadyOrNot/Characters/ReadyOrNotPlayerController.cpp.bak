void AReadyOrNotPlayerController::SetPawn(APawn* InPawn)
{
	if (InPawn)
	{
		// Fixes glitchy camera in the customization viewport
		if (!InPawn->Tags.Contains("OrbitalCameraActor"))
		{
			bAutoManageActiveCameraTarget = true;
		}
		else
		{
			bAutoManageActiveCameraTarget = false;
		}

		

	}
	Super::SetPawn(InPawn);

	if (bAutoManageActiveCameraTarget)
	{
		Client_SetViewTargetWithBlend(InPawn);
		Client_SetViewTargetWithBlend_Implementation(InPawn);
	}
	OnPawnPossessed.Broadcast(InPawn);
}

void AReadyOrNotPlayerController::PawnLeavingGame()
{
	if (!GetWorld())
		return;

	AReadyOrNotGameMode* GM = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();

	if (!GM)
		return;
	
	if (APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn()))
	{
		if (GM->GetMatchState() == EMatchState::MS_Playing && !Cast<ALobbyGM>(GM))
		{
			pc->OnCharacterKilled.RemoveAll(GM);
			pc->GetHealthComponent()->OnPawnLeavingGame();
			pc->Kill();
			pc->SetLifeSpan(5.0f);
		}
		else
		{
			Super::PawnLeavingGame();
		}
	}
	else
	{
		Super::PawnLeavingGame();
	}
}

void AReadyOrNotPlayerController::SetupInputComponent()
{
	Super::SetupInputComponent();

	InputComponent->BindAction("PushToTalk", IE_Pressed, this, &AReadyOrNotPlayerController::StartSpeaking);
	InputComponent->BindAction("PushToTalk", IE_Released, this, &AReadyOrNotPlayerController::StopSpeaking);
	InputComponent->BindAction("CycleVoiceChannel", IE_Pressed, this, &AReadyOrNotPlayerController::CycleVoiceChannel);
	//InputComponent->BindAction("VoteYes", IE_Pressed, this, &AReadyOrNotPlayerController::VoteYes);
	//InputComponent->BindAction("VoteNo", IE_Pressed, this, &AReadyOrNotPlayerController::VoteNo);
	InputComponent->BindAction("RTXOnOff", IE_Pressed, this, &AReadyOrNotPlayerController::ToggleRTXDMO);
	// InputComponent->BindAction("EscapeMenu", IE_Pressed, this, &AReadyOrNotPlayerController::EscapeMenu);
	InputComponent->BindAction("EscapeMenu", IE_Pressed, this, &AReadyOrNotPlayerController::OpenPauseMenu);
	InputComponent->BindAction("SpectateNextPlayer", IE_Released, this, &AReadyOrNotPlayerController::SpectateNextPlayer);
	InputComponent->BindAction("SpectatePreviousPlayer", IE_Pressed, this, &AReadyOrNotPlayerController::SpectatePreviousPlayer);
	
	FInputActionBinding& ShowTabMenuBinding = InputComponent->BindAction("ViewScoreboard", IE_Pressed, this, &AReadyOrNotPlayerController::ShowTabMenu);
	FInputActionBinding& HideTabMenuBinding = InputComponent->BindAction("ViewScoreboard", IE_Released, this, &AReadyOrNotPlayerController::HideTabMenu);
	ShowTabMenuBinding.bConsumeInput = false;
	HideTabMenuBinding.bConsumeInput = false;

	FInputActionBinding& ReadyUpBinding = InputComponent->BindAction("ReadyUp", IE_Pressed, this, &AReadyOrNotPlayerController::ReadyUp);
	ReadyUpBinding.bConsumeInput = false;

	// in case the "Ready Up" key binding was unbound, due to exisiting key binding save data,
	// make sure we can still launch into missions by falling back on a hardcoded key bind, the Y key
	FInputKeyBinding& KeyBinding = InputComponent->BindKey(EKeys::Y, IE_Pressed, this, &AReadyOrNotPlayerController::ReadyUp_Failsafe);
	KeyBinding.bConsumeInput = false;
}

void AReadyOrNotPlayerController::ClientSpawned_Implementation()
{
	// This is also called on the server.
	AReadyOrNotPlayerState* ps = GetPlayerState<AReadyOrNotPlayerState>();
	if (ps)
	{
		ps->TimeAlive = 0.0f;

		if (GetLocalRole() >= ROLE_Authority)
		{
			ps->ArrestsThisLife = 0;
			ps->KillsThisLife = 0;
			ps->ResetBulletsFired();
			ps->BulletsBlocked = 0;
			ps->HitsReceived = 0;
		}
	}
}

void AReadyOrNotPlayerController::Server_StartSpectating_Implementation()
{
	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		if (gm->GetRandomSafeStart())
		{
			FTransform RandomTransform = gm->GetRandomSafeStart()->GetActorTransform();
			RandomTransform.SetLocation(RandomTransform.GetLocation() + FVector(0.0f, 0.0f, 100.0f));
			gm->SpawnSpectator(this, gm->DeadSpectatorClass, RandomTransform);
			Client_SetControlRotation(RandomTransform.GetRotation().Rotator());
		}
		
	}
}

bool AReadyOrNotPlayerController::Server_StartSpectating_Validate()
{
