void AReadyOrNotPlayerController::PossessOrbitalCamera()
{
// Allow psosession withut authority because this camera is on a streamed level that may not be valid on the server
	bCanPossessWithoutAuthority = true;
	for (TActorIterator<APawn> It(GetWorld()); It; ++It)
	{
		APawn* p = *It;
		if (p->Tags.Contains("OrbitalCameraActor"))
		{
			Possess(p);
			break;
		}
	}
	bCanPossessWithoutAuthority = false;
} 

