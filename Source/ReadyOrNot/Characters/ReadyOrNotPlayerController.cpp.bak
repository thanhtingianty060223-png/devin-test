ETeamType AReadyOrNotPlayerController::GetTeamType()
{
	AReadyOrNotPlayerState* Ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (Ps)
	{
		return Ps->GetTeam();
	}
	return ETeamType::TT_NONE;
}

void AReadyOrNotPlayerController::Server_SetTeamType_Implementation(ETeamType NewTeam)
{
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (pc && pc->IsArrested())
	{
		// don't allow switching teams while we're arrested --eez
		SendChatMessage(FRChatMessage("SYSTEM", "You cannot switch teams while arrested", FLinearColor::Yellow, this));
		return;
	}

	FString systemMsg = "";
	if (NewTeam == ETeamType::TT_SERT_BLUE)
	{
		systemMsg = "You joined SERT Blue";
	}
	else if (NewTeam == ETeamType::TT_SERT_RED)
	{
		systemMsg = "You joined SERT Red";
	}
	else if (GetTeamType() == ETeamType::TT_SUSPECT)
	{
		systemMsg = "You joined Suspects";
	}
	SendChatMessage(FRChatMessage("SYSTEM", systemMsg, FLinearColor::Yellow, this));
	AReadyOrNotPlayerState* Ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (Ps)
	{
		if (NewTeam != Team)
		{
			AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
			if (gm)
			{
				gm->RespawnPlayer(this);
			}
		}
		Ps->Server_SetTeam(NewTeam);
	}
	Team = NewTeam;
}

void AReadyOrNotPlayerController::Vote_Implementation(const bool VoteYes)
{
	if (!HasAuthority())
		return;
	
	if (!MyVoteData.bVoteEnabled)
		return;

	// Spectators can't vote
	if (!GetPlayerState<AReadyOrNotPlayerState>() || (GetPlayerState<AReadyOrNotPlayerState>() && GetPlayerState<AReadyOrNotPlayerState>()->IsSpectator()))
		return;

	ACoopGS* GS = GetWorld()->GetGameState<ACoopGS>();
	if (!IsValid(GS))
		return;

	// Prevent player from closing soft vote menu when there's only one player
	if(!VoteYes && GS->GetPlayersAvailableForVote().Num() < 2)
		return;

	// GS handles updating our vote state. If vote wasn't allowed, don't acknowledge
	if (GS->PlayerControllerVoted(this, VoteYes))
		AcknowledgeVote(MyVoteData);	
}

void AReadyOrNotPlayerController::BeginVote_Implementation(const FString& Reason, const FString& Question, const bool bCanVoteNo)
{
	if (MyVoteData.VoteReason != Reason)
	{
		MyVoteData.bVoteEnabled = true;
		MyVoteData.VoteReason = Reason;
		MyVoteData.VoteQuestion = Question;
		MyVoteData.CurrentVoteState = EVoteState::Undecided;
		MyVoteData.bCanVoteNo = bCanVoteNo;
		RequestVoteInput(MyVoteData);
	}
}

void AReadyOrNotPlayerController::EndVote_Implementation()
{
	MyVoteData = FVoteData();

	StopVoteInput();
}

EVoteState AReadyOrNotPlayerController::GetVote() 
{
	return MyVoteData.CurrentVoteState;
}

void AReadyOrNotPlayerController::Client_ClearHUDWidgets_Implementation()
{
	// todo: store cached widgets and not search through this, very slow...
	for (TObjectIterator<UUserWidget> Itr; Itr; ++Itr)
	{
		UUserWidget* LiveWidget = *Itr;
		
		// if the widget has no world, ignore it (it's probably in the content browser!)
		if (!LiveWidget->GetWorld() || LiveWidget->GetWorld() != GetWorld() || !LiveWidget->IsInViewport())
		{
			continue;
		}

		if (LiveWidget->IsA(ULoadingScreen::StaticClass()) ||
			LiveWidget->IsA(UPreMissionPlanning::StaticClass()) ||
			LiveWidget->IsA(UHumanCharacterHUD_V2::StaticClass()))
		{
			LiveWidget->RemoveFromParent();
		}
	}
	
	RecreateOverlays();
	
	OnHudWidgetsClearedComplete.Broadcast();
}

void AReadyOrNotPlayerController::RemoveLoadingScreen()
{
	if (IsRunningDedicatedServer())
		return;

	if (!IsLocalController())
		return;

	UReadyOrNotStatics::GetReadyOrNotGameInstance()->bClientHasFinishedLoading = true;
	Server_SetHasFinishedLoading();
	if (HasAuthority())
	{
		AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
		if (gs)
		{
			gs->bHasHostFinishedLoading = true;
		}
	} else
	{
		AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
		if (!gs || !gs->bHasHostFinishedLoading)
		{
			UReadyOrNotStatics::GetReadyOrNotGameInstance()->bPendingRemoveLoadingScreenAfterHostLoaded = true;
			return;
		}
	}
	
	UReadyOrNotStatics::GetReadyOrNotGameInstance()->bPendingRemoveLoadingScreenAfterHostLoaded = false;
	
	for (TObjectIterator<UUserWidget> Itr; Itr; ++Itr)
	{
		UUserWidget* LiveWidget = *Itr;
		/* If the Widget has no World, Ignore it (It's probably in the Content Browser!) */
		if (!LiveWidget->GetWorld() || LiveWidget->GetWorld() != GetWorld() || !LiveWidget->IsInViewport())
		{
			continue;
		}

		if (ULoadingScreen* LoadingScreen = Cast<ULoadingScreen>(LiveWidget))
		{
			LoadingScreen->DeactivateWidget();
			LiveWidget->RemoveFromParent();
		}
	}
	AReadyOrNotGameState* ReadyOrNotGameState = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (ReadyOrNotGameState)
	{
		ReadyOrNotGameState->LoadStartupWidgetsAfterLoadingScreen();
	}
	OnLoadingScreenCleared.Broadcast();
}

bool AReadyOrNotPlayerController::HasLoadingScreenInViewport()
{
	for (TObjectIterator<UUserWidget> Itr; Itr; ++Itr)
	{
		UUserWidget* LiveWidget = *Itr;
		/* If the Widget has no World, Ignore it (It's probably in the Content Browser!) */
		if (!LiveWidget->GetWorld() || LiveWidget->GetWorld() != GetWorld() || !LiveWidget->IsInViewport())
		{
			continue;
		}

		if (LiveWidget->IsA(ULoadingScreen::StaticClass()))
		{
			return true;
		}
	}
	return false;
}

void AReadyOrNotPlayerController::Client_HideHUDWidgets_Implementation()
{
	if (APlayerCharacter* PC = Cast<APlayerCharacter>(GetPawn()))
	{
		if (PC->HumanCharacterWidget_V2)
		{
			PC->HumanCharacterWidget_V2->HideHUD();
		}
	}
}

void AReadyOrNotPlayerController::Client_RemoveWidget_Implementation(TSubclassOf<UUserWidget> Widget)
{
	if (!Widget)
		return;

	for (TObjectIterator<UUserWidget> Itr; Itr; ++Itr)
	{
		UUserWidget* LiveWidget = *Itr;
		if (LiveWidget && LiveWidget->IsA(Widget))
		{
			LiveWidget->RemoveFromParent();
		}
	}
}

