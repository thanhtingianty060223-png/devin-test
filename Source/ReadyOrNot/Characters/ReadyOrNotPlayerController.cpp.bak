bool AReadyOrNotPlayerController::ServerBeginSteamAuth_Validate(FSteamAuthenticationToken AuthToken)
{
	return true;
}

void AReadyOrNotPlayerController::ServerBeginSteamAuth_Implementation(FSteamAuthenticationToken AuthToken)
{
	if (SteamGameServer())
	{
		uint8 rgchToken[1024];
		StringToBytes(AuthToken.rgchTokenString, rgchToken, 1024);

		OnAuthTicketResponseCallback.Register(this, &AReadyOrNotPlayerController::OnAuthTicketResponse);
		
		V_LOGM(LogReadyOrNot, "Starting Steam Authentication for %s [%s]",
                *FString::Printf(TEXT("%lld"), AuthToken.steamid), *FString::FromInt(m_hAuthTicket));
		ClientsAuthToken = AuthToken;
		if (k_EBeginAuthSessionResultOK != SteamGameServer()->BeginAuthSession(rgchToken, AuthToken.unTokenLen, AuthToken.steamid))
		{
			ClientReturnToMainMenuWithTextReason(NSLOCTEXT("ReadyOrNot", "UnableToAuthenticateWithSteam", "Unable to Authenticate with steam"));
			SteamGameServer()->EndAuthSession(AuthToken.steamid);
		} else
		{
			V_LOGM(LogReadyOrNot, "Steam Auth for %s verified succesfully!",
                *FString::Printf(TEXT("%lld"), AuthToken.steamid));
		}
	}

}

void AReadyOrNotPlayerController::CancelSteamAuthForPlayerController()
{
	V_LOGM(LogReadyOrNot, "Canceling Steam Authentication for %s [%s]",
		*FString::Printf(TEXT("%lld"), ClientsAuthToken.steamid), *FString::FromInt(m_hAuthTicket));

	AReadyOrNotGameMode* ReadyOrNotGameMode = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();
	if (ReadyOrNotGameMode)
	{
		if (SteamGameServer())
		{
			if (ClientsAuthToken.steamid != 0)
			{
				SteamGameServer()->EndAuthSession(ClientsAuthToken.steamid);
			}
		}
		// update the server affter a small delay
		FTimerHandle DummyTimer;
		GetWorld()->GetTimerManager().SetTimer(DummyTimer, ReadyOrNotGameMode, &AReadyOrNotGameMode::RefreshSession, 3.0f, false);
	} else
	{
		if (SteamUser())
		{
			if (m_hAuthTicket != k_HAuthTicketInvalid)
			{
				SteamUser()->CancelAuthTicket(m_hAuthTicket);
			}
			
		}
	}
}


