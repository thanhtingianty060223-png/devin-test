				ASWATCharacter* SWAT = *SWATIt;
				SWAT->GetInventoryComponent()->AddInventoryItem(Ram);
				return;
			}

		}

	}
	
}

void AReadyOrNotPlayerController::WinCoop()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	for (TActorIterator<ACyberneticCharacter>It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* Ai = *It;
		if (Ai->GetTeam() == ETeamType::TT_SUSPECT || Ai->GetTeam() == ETeamType::TT_CIVILIAN)
		{
			if (!Ai->IsDeadOrUnconscious())
			{
				Ai->Surrender();
				Ai->ArrestComplete(Cast<APlayerCharacter>(GetPawn()), Cast<AZipcuffs>(Cast<APlayerCharacter>(GetPawn())->GetInventoryComponent()->GetInventoryItemOfClass(AZipcuffs::StaticClass())));
			}
			
			IReportable::Execute_ReportToTOC(Ai, Cast<APlayerCharacter>(GetPawn()), false);
		}
	}
	for (TActorIterator<ABaseItem>It(GetWorld()); It; ++It)
	{
		ABaseItem* Item = *It;
		if (Item->IsEvidence())
		{
			Cast<APlayerCharacter>(GetPawn())->Server_CollectEvidence_Implementation(Item);
		}
	}

	for (TActorIterator<AIncapacitatedHuman>It(GetWorld()); It; ++It)
	{
		Cast<APlayerCharacter>(GetPawn())->Server_ReportToTOC(*It);
	}

	for (TActorIterator<ATrapActor>It(GetWorld()); It; ++It)
	{
		It->OnTrapDisarmed();
	}
	for (TActorIterator<AEvidenceActor>It(GetWorld()); It; ++It)
	{
		AEvidenceActor* EvidenceActor = *It;
		EvidenceActor->ActorPickedUp(GetPawn());
	}

	for (TObjectIterator<UScoringComponent>It; It; ++It)
	{
		if (It->bEnabled && !It->ScoringData.HasGivenAllScores())
		{
			if (It->GetWorld() == GetWorld())
			{
				V_LOGM(LogReadyOrNot, "%s has not given all scoring data (Owner: %s)", *It->GetName(), *It->GetOwner()->GetName());
			}
		}
	}
}

