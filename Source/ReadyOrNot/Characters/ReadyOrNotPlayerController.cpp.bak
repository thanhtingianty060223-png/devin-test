bool AReadyOrNotPlayerController::IsAFK(float AFKTime)
{
	// explicitly defined. cant afk while dead or specating.. only kick when they're actually alive
	if (Cast<ASpectatePawn>(GetPawn()))
	{
		return false;
	}

	return SecondsSinceLastMovement > AFKTime;
}


