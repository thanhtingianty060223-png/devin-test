void AReadyOrNotPlayerController::TeleportToNextRemainingAI()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	if (!GetPawn())
		return;
	for (TActorIterator<ACyberneticCharacter>It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* AICharacter = *It;
		if (AICharacter->IsOnSWATTeam() && (!AICharacter->IsDeadOrUnconscious() || (AICharacter->IsDeadOrUnconscious() && AICharacter->HasBeenReported())))
			continue;
		
		if ((!AICharacter->IsArrested() && !AICharacter->IsDeadOrUnconscious()) || !AICharacter->HasBeenReported())
		{
			GetPawn()->SetActorLocation(AICharacter->GetActorLocation() + AICharacter->GetActorForwardVector() * 75.0f);
			SetControlRotation(UKismetMathLibrary::FindLookAtRotation(GetPawn()->GetActorLocation(), AICharacter->GetActorLocation()));
		}
	}
}

