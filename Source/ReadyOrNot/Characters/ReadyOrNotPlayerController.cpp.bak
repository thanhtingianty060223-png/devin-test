void AReadyOrNotPlayerController::ArrestAll(ETeamType TargetTeam)
{
#if UE_BUILD_DEVELOPMENT
	if (!GetPawn())
		return;
	
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* CyberneticCharacter = *It;
		if (CyberneticCharacter && CyberneticCharacter->GetTeam() == TargetTeam)
		{
			CyberneticCharacter->Surrender();
			CyberneticCharacter->ArrestComplete(Cast<APlayerCharacter>(GetPawn()),
				Cast<AZipcuffs>(Cast<APlayerCharacter>(GetPawn())->GetInventoryComponent()->GetInventoryItemOfClass(AZipcuffs::StaticClass())));
		}
	}
#endif
}

void AReadyOrNotPlayerController::KillAll(ETeamType TargetTeam)
{
#if UE_BUILD_DEVELOPMENT
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		if (!GetPawn())
			return;
	
		ACyberneticCharacter* CyberneticCharacter = *It;
		if (CyberneticCharacter && CyberneticCharacter->GetTeam() == TargetTeam)
		{
			FDamageEvent ConsoleDamageEvent = FDamageEvent();
			ConsoleDamageEvent.DamageTypeClass = UDamageType::StaticClass();
			CyberneticCharacter->TakeDamage(999.0f, ConsoleDamageEvent, nullptr, CyberneticCharacter);
		}
	}
#endif
}

void AReadyOrNotPlayerController::PlayDeadAllEnemies()
{
#if UE_BUILD_DEVELOPMENT
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* cc = *It;
		if (cc->GetTeam() == ETeamType::TT_SUSPECT)
		{
			cc->PlayDead(10.0f, false);
		} else  
		{
			cc->Destroy();
		}
	}
#endif
}

void AReadyOrNotPlayerController::DestroyAllWidgets()
{
#if UE_BUILD_DEVELOPMENT

	for (TObjectIterator<UUserWidget> Itr; Itr; ++Itr)
	{
		UUserWidget* LiveWidget = *Itr;

		/* If the Widget has no World, Ignore it (It's probably in the Content Browser!) */
		if (!LiveWidget->GetWorld() || LiveWidget->GetWorld() != GetWorld() || !LiveWidget->IsInViewport())
		{
			continue;
		}
		
		LiveWidget->RemoveFromParent();
	}
#endif
}

void AReadyOrNotPlayerController::ToggleRTXDMO()
{
#if UE_BUILD_DEVELOPMENT

#if defined RTX_DMO
	if (UBpVideoSettingsLib::SupportsRayTracing())
	{

		bRTXDMOOn = !bRTXDMOOn;
	}
	else
	{
		bRTXDMOOn = false;
	}
	FString ToggleRTXStr = (bRTXDMOOn ? "On" : "Off");
	V_LOGM(LogReadyOrNot, "Toggle RTX %s", *ToggleRTXStr);
	OnRTXDMOChanged.Broadcast(bRTXDMOOn);
	UReadyOrNotGameUserSettings* Settings = Cast<UReadyOrNotGameUserSettings>(GEngine->GameUserSettings);
	if (Settings)
	{
		Settings->bRayTracingEnabled = bRTXDMOOn;
		Settings->ApplySettings(true);
	}
#endif
#endif
}

void AReadyOrNotPlayerController::ArrestOne()
