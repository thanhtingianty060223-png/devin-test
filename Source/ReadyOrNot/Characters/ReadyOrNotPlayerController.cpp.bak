void AReadyOrNotPlayerController::DebugDrawDebugActors(float DeltaTime)
{
#if !UE_BUILD_SHIPPING
	for (const auto& kvPair : DebugActorList)
	{
		if (!DebugActorList.Contains(kvPair.Key))
			continue;
		DebugActorList[kvPair.Key] -= DeltaTime;
		if (kvPair.Value <= 0.0f)
			continue;

		if (!kvPair.Key)
			continue;
		
		IGatherDebugInterface* DebugInterface = Cast<IGatherDebugInterface>(kvPair.Key);
		if (DebugInterface)
		{
			FString OutText;
			DebugInterface->Execute_DrawVisualDebug(kvPair.Key);
			DebugInterface->Execute_GatherDebugText(kvPair.Key, OutText);

			if (!OutText.IsEmpty())
				GEngine->AddOnScreenDebugMessage(-1, 0, FColor::White, OutText);
		}
	}
#endif
}

