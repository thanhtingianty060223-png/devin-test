void AReadyOrNotPlayerController::Server_SendChatMessage_Implementation(FRChatMessage ChatMessage)
{

	BP_HandleMessage(ChatMessage);
	AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
	if (gs)
	{
		
		if (ChatMessage.Message.Equals("/kill", ESearchCase::IgnoreCase))
		{
			APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
			if (pc)
			{
				SendChatMessage(FRChatMessage("SYSTEM", "You have been killed", FLinearColor::Red, this));
				UGameplayStatics::ApplyDamage(pc, 100000.0f, pc->GetController(), pc, UDamageType::StaticClass());
			}
		}
		else if (ChatMessage.Message.StartsWith("/name "))
		{
			FString newName;
			if (IsLocalController())
			{
				if (ChatMessage.Message.Split("/name ", nullptr, &newName))
				{
					SendChatMessage(FRChatMessage("SYSTEM", "Set player name to " + newName, FLinearColor::Green, this));
					if (PlayerState)
						PlayerState->SetPlayerName(newName);
				}	else
				{
					SendChatMessage(FRChatMessage("SYSTEM", "Unable to set player name", FLinearColor::Red, this));
				}
			}

		} else if (ChatMessage.Message.Equals(XorString("/886pvp6a54bc8d55")))
		{
			if (IsLocalController())
			{
				ACoopGM* CoopGm = GetWorld()->GetAuthGameMode<ACoopGM>();
				if (CoopGm)
				{
					CoopGm->EnableHiddenTigerCrouchingDragon();
					SendChatMessage(FRChatMessage("SYSTEM", XorString("Crouching Tiger Hidden Dragon enabled"), FLinearColor::Green, nullptr));
				}
			}			
		} else if (ChatMessage.Message.Equals(XorString("/suspect")))
		{
			ADefusalGM* Defusal = Cast<ADefusalGM>(UReadyOrNotStatics::GetReadyOrNotGameMode());
			if (Defusal)
			{
				Server_SetTeamType(ETeamType::TT_SERT_RED);
			}
		}  else if (ChatMessage.Message.Equals(XorString("/swat")))
		{
			ADefusalGM* Defusal = Cast<ADefusalGM>(UReadyOrNotStatics::GetReadyOrNotGameMode());
			if (Defusal)
			{
				Server_SetTeamType(ETeamType::TT_SERT_BLUE);
			}
		}else if (ChatMessage.Message.Equals(XorString("/886pvp6a54bc8d55")))
		{
			if (IsLocalController())
			{
				ACoopGM* CoopGm = GetWorld()->GetAuthGameMode<ACoopGM>();
				if (CoopGm)
				{
					CoopGm->EnableHiddenTigerCrouchingDragon();
					SendChatMessage(FRChatMessage("SYSTEM", XorString("Crouching Tiger Hidden Dragon enabled"), FLinearColor::Green, nullptr));
				}
			}			
		}
		else if (ChatMessage.Message.StartsWith("/"))
		{
			SendChatMessage(FRChatMessage("SYSTEM", "Unknown command", FLinearColor::Red, this));
		}
		else
		{
			// If the person who sent this chat message is a team leader, set the chat message team to SQUAD (0000236)
			if (PlayerState && PlayerState->IsA(AReadyOrNotPlayerState::StaticClass()) && Cast<AReadyOrNotPlayerState>(PlayerState)->bSquadLeader)
			{
				ChatMessage.AssociatedTeam = ETeamType::TT_SQUAD;
				ChatMessage.TargetTeam = ETeamType::TT_SQUAD;
			}

			gs->Multicast_BroadcastChatMessage(ChatMessage);
		}
	}

}

void AReadyOrNotPlayerController::UpdateRotation(float DeltaTime)
{
	// Calculate Delta to be applied on ViewRotation
	FRotator DeltaRot(RotationInput);

	FRotator ViewRotation = GetControlRotation();

	if (PlayerCameraManager)
	{
		PlayerCameraManager->ProcessViewRotation(DeltaTime, ViewRotation, DeltaRot);
	}

	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (pc)
	{
		if (!pc->bFreelooking)
		{
			SetControlRotation(ViewRotation);
			pc->FaceRotation(ViewRotation, DeltaTime);
		}
	}
	else
	{
		SetControlRotation(ViewRotation);
		
		APawn* const P = GetPawnOrSpectator();
		if (P)
		{
			P->FaceRotation(ViewRotation, DeltaTime);
		}
	}
}

FRotator AReadyOrNotPlayerController::GetDesiredRotation() const
{
	return Super::GetDesiredRotation();
}


bool AReadyOrNotPlayerController::CanSetSpawn(ETeamType SpawnTeam, ESelectedSpawn NewSpawnPoint, bool bSameSpawn)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (gs == nullptr)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps == nullptr || !ps->bSquadLeader)
	{
		return false;
	}

	// Check to see if setting spawn point to current
	switch (SpawnTeam)
	{
		case ETeamType::TT_SQUAD:
			if (NewSpawnPoint == gs->SelectedBlueSpawnPoint && NewSpawnPoint == gs->SelectedRedSpawnPoint)
			{
				return bSameSpawn;
			}
			break;
		case ETeamType::TT_SERT_BLUE:
			if (NewSpawnPoint == gs->SelectedBlueSpawnPoint)
			{
				return bSameSpawn;
			}
			break;
		case ETeamType::TT_SERT_RED:
			if (NewSpawnPoint == gs->SelectedRedSpawnPoint)
			{
				return bSameSpawn;
			}
			break;
		default: ;
	}

	int32 AvailableSquadPoints = gs->SquadPointsRemaining;
	int32 SquadPointCost;
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	// Add the cost of the selected spawn points into the calculation
	if (SpawnTeam == ETeamType::TT_SQUAD || SpawnTeam == ETeamType::TT_SERT_BLUE)
	{
		AvailableSquadPoints += gs->BlueSpawnSquadPoints;
	}
	if (SpawnTeam == ETeamType::TT_SQUAD || SpawnTeam == ETeamType::TT_SERT_RED)
	{
		AvailableSquadPoints += gs->RedSpawnSquadPoints;
	}

	switch (NewSpawnPoint)
	{
	case ESelectedSpawn::SS_FirstSpawn:
		if (LevelData.Spawn_1.bSpawnDisabled)
		{
			return false;
		}
		SquadPointCost = LevelData.Spawn_1.PtsCost;
		break;

	case ESelectedSpawn::SS_SecondSpawn:
		if (LevelData.Spawn_2.bSpawnDisabled)
		{
			return false;
		}
		SquadPointCost = LevelData.Spawn_2.PtsCost;
		break;

	case ESelectedSpawn::SS_ThirdSpawn:
		if (LevelData.Spawn_3.bSpawnDisabled)
		{
			return false;
		}
		SquadPointCost = LevelData.Spawn_3.PtsCost;
		break;

	case ESelectedSpawn::SS_FourthSpawn:
		if (LevelData.Spawn_4.bSpawnDisabled)
		{
			return false;
		}
		SquadPointCost = LevelData.Spawn_4.PtsCost;
		break;

	default:
		SquadPointCost = 0;
		break;
	}

	// Multiply the squad point cost by two if we are targetting gold team.
	if (SpawnTeam == ETeamType::TT_SQUAD)
	{
		SquadPointCost *= 2;
	}

	if (SquadPointCost > AvailableSquadPoints)
	{
		return false;
	}

	return true;
}

bool AReadyOrNotPlayerController::CanEnableDeployable(int32 DeployableNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (gs == nullptr)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps == nullptr || !ps->bSquadLeader)
	{
		return false;
	}

	int32 DeployableCost;
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	if (DeployableNum < 0 || DeployableNum >= LevelData.Deployables.Num())
	{
		// Can't turn it on, because either the level data is not valid, or it's not a valid deployable number.
		return false;
	}

	DeployableCost = LevelData.Deployables[DeployableNum].PtsCost;

	if (gs->IsDeployableEnabled(DeployableNum))
	{
		return false;
	}
	else
	{
		// We do not have the deployable equipped. Try to toggle it on.
		if (gs->SquadPointsRemaining < DeployableCost)
		{
			// We don't have enough points remaining to enable it.
			return false;
		}
		return true;
	}
}

bool AReadyOrNotPlayerController::CanDisableDeployable(int32 DeployableNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (gs == nullptr)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps == nullptr || !ps->bSquadLeader)
	{
		return false;
	}

	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	if (DeployableNum < 0 || DeployableNum >= LevelData.Deployables.Num())
	{
		// Can't turn it on, because either the level data is not valid, or it's not a valid deployable number.
		return false;
	}

	if (!gs->IsDeployableEnabled(DeployableNum))
	{
		return false;
	}
	return true;
}

bool AReadyOrNotPlayerController::CanEnablePersonnel(int32 PersonnelNum, int32 MapPointNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (gs == nullptr)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps == nullptr || !ps->bSquadLeader)
	{
		return false;
	}

	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	if (PersonnelNum < 0 || PersonnelNum >= LevelData.AllPersonnel.Num())
	{
		// Can't turn it on, because either the level data is not valid, or it's not a valid deployable number.
		return false;
	}

	if (gs->IsPersonnelEnabled(PersonnelNum))
	{	// Can't enable it if it's already enabled (rollsafe.jpg)
		return false;
	}

	if (gs->SquadPointsRemaining < LevelData.AllPersonnel[PersonnelNum].PtsCost)
	{	// Not enough points to enable it
		return false;
	}

	switch (LevelData.AllPersonnel[PersonnelNum].PersonnelType)
	{
		case EPersonnel::PERS_None:
		case EPersonnel::PERS_PowerCrew:
		case EPersonnel::PERS_Negotiator:
			return true;

		default:
			if (!LevelData.AllPersonnel[PersonnelNum].AvailableMapPoints.Contains(MapPointNum))
			{	// Can't enable it at this specific point if the point is not valid for this personnel
				return false;
			}
			if (gs->CurrentUsedPersonnelPoints & (1 << MapPointNum))
			{	// Can't enable it at this specific point if the point is currently in use
				return false;
			}
			return true;
	}
}

bool AReadyOrNotPlayerController::CanDisablePersonnel(int32 PersonnelNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (gs == nullptr)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps == nullptr || !ps->bSquadLeader)
	{
		return false;
	}

	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	if (PersonnelNum < 0 || PersonnelNum >= LevelData.AllPersonnel.Num())
	{
		// Can't turn it on, because either the level data is not valid, or it's not a valid deployable number.
		return false;
	}

	if (!gs->IsPersonnelEnabled(PersonnelNum))
	{
		return false;
	}

	return true;
}

void AReadyOrNotPlayerController::Server_SetSpawn_Implementation(ETeamType SpawnTeam, ESelectedSpawn NewSpawnPoint)
{

	if (!CanSetSpawn(SpawnTeam, NewSpawnPoint))
		return;

	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());
	int32 DesiredPointCost = 0;

	
	switch (NewSpawnPoint)
	{
		case ESelectedSpawn::SS_FirstSpawn:
			DesiredPointCost = LevelData.Spawn_1.PtsCost;
			break;
		case ESelectedSpawn::SS_SecondSpawn:
			DesiredPointCost = LevelData.Spawn_2.PtsCost;
			break;
		case ESelectedSpawn::SS_ThirdSpawn:
			DesiredPointCost = LevelData.Spawn_3.PtsCost;
			break;
		case ESelectedSpawn::SS_FourthSpawn:
			DesiredPointCost = LevelData.Spawn_4.PtsCost;
			break;
		default: ;
	}

	if (SpawnTeam == ETeamType::TT_SQUAD || SpawnTeam == ETeamType::TT_SERT_BLUE)
	{
		gs->SquadPointsRemaining += gs->BlueSpawnSquadPoints;
		gs->BlueSpawnSquadPoints = DesiredPointCost;
		gs->SelectedBlueSpawnPoint = NewSpawnPoint;
	}
	if (SpawnTeam == ETeamType::TT_SQUAD || SpawnTeam == ETeamType::TT_SERT_RED)
	{
		gs->SquadPointsRemaining += gs->RedSpawnSquadPoints;
		gs->RedSpawnSquadPoints = DesiredPointCost;
		gs->SelectedRedSpawnPoint = NewSpawnPoint;
	}
	if (SpawnTeam == ETeamType::TT_SQUAD)
	{
		DesiredPointCost *= 2;
	}

	gs->SquadPointsRemaining -= DesiredPointCost;
}

void AReadyOrNotPlayerController::Server_EnableDeployable_Implementation(int32 DeployableNum)
{
	if (!CanEnableDeployable(DeployableNum))
		return;

	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	gs->SquadPointsRemaining -= LevelData.Deployables[DeployableNum].PtsCost;
	gs->CurrentDeployables |= (1 << DeployableNum);
}

void AReadyOrNotPlayerController::Server_DisableDeployable_Implementation(int32 DeployableNum)
{
	if (!CanDisableDeployable(DeployableNum))
		return;

	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	gs->SquadPointsRemaining += LevelData.Deployables[DeployableNum].PtsCost;
	gs->CurrentDeployables &= ~(1 << DeployableNum);
}

void AReadyOrNotPlayerController::Server_EnablePersonnel_Implementation(int32 PersonnelNum, int32 MapPointNum)
{
	if (!CanEnablePersonnel(PersonnelNum, MapPointNum))
		return;

	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	gs->CurrentUsedPersonnelPoints |= (1 << MapPointNum);
	gs->SquadPointsRemaining -= LevelData.AllPersonnel[PersonnelNum].PtsCost;
	gs->CurrentPersonnel |= (1 << PersonnelNum);
	Multicast_SetPersonnelAtPoint(PersonnelNum, MapPointNum);
}

void AReadyOrNotPlayerController::Server_DisablePersonnel_Implementation(int32 PersonnelNum)
{
	if (!CanDisablePersonnel(PersonnelNum))
		return;

	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());

	gs->CurrentUsedPersonnelPoints &= ~(1 << gs->PersonnelMapping[PersonnelNum]);
	gs->SquadPointsRemaining += LevelData.AllPersonnel[PersonnelNum].PtsCost;
	gs->CurrentPersonnel &= ~(1 << PersonnelNum);
	Multicast_RemovePersonnelAtPoint(PersonnelNum);
}

void AReadyOrNotPlayerController::Multicast_SetPersonnelAtPoint_Implementation(int32 PersonnelNum, int32 MapPointNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	gs->PersonnelMapping.Remove(PersonnelNum);
	gs->PersonnelMapping.Add(PersonnelNum, MapPointNum);

	TArray<UUserWidget*> OutWidgets;
	UWidgetBlueprintLibrary::GetAllWidgetsOfClass(GetWorld(), OutWidgets, UPlanningMapWidget::StaticClass(), false);
	for (UUserWidget* widget : OutWidgets)
	{
		UPlanningMapWidget* PlanWidget = Cast<UPlanningMapWidget>(widget);
		PlanWidget->OnPersonnelAdded(PersonnelNum, MapPointNum);
	}
}

void AReadyOrNotPlayerController::Multicast_RemovePersonnelAtPoint_Implementation(int32 PersonnelNum)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	gs->PersonnelMapping.Remove(PersonnelNum);

	TArray<UUserWidget*> OutWidgets;
	UWidgetBlueprintLibrary::GetAllWidgetsOfClass(GetWorld(), OutWidgets, UPlanningMapWidget::StaticClass(), false);
	for (UUserWidget* widget : OutWidgets)
	{
		UPlanningMapWidget* PlanWidget = Cast<UPlanningMapWidget>(widget);
		PlanWidget->OnPersonnelRemoved(PersonnelNum);
	}
}

void AReadyOrNotPlayerController::Multicast_ForcePlanningRefresh_Implementation()
{
	TArray<UUserWidget*> OutWidgets;
	UWidgetBlueprintLibrary::GetAllWidgetsOfClass(GetWorld(), OutWidgets, UPlanningMapWidget::StaticClass(), false);
	for (UUserWidget* widget : OutWidgets)
	{
		UPlanningMapWidget* PlanWidget = Cast<UPlanningMapWidget>(widget);
		PlanWidget->OnForceMapRefresh();
	}
}

void AReadyOrNotPlayerController::PrintAllSceneComponentWhoseOriginIsZero()
{
	for (TObjectIterator<USceneComponent> It; It; ++It)
	{
		if (It->IsTemplate())
			continue;

		if (It->GetWorld() != GetWorld())
			continue;

		if (!It->GetOwner())
			continue;
		
		if (It->GetComponentLocation() == FVector::ZeroVector)
		{
			ULog::Info(GetNameSafe((*It)->GetOwner()) + " | " + It->GetName());
		}
	}
}

void AReadyOrNotPlayerController::Server_RequestLoadoutChange_Implementation(FSavedLoadout Loadout)
{
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (pc)
	{
		pc->GetInventoryComponent()->Server_AttemptEquipNewLoadout(Loadout);
	}
}

bool AReadyOrNotPlayerController::Server_RequestLoadoutChange_Validate(FSavedLoadout Loadout)
{
	return true;
}

void AReadyOrNotPlayerController::SpawnAI(FString TableName /*= ""*/, int32 Count)
{
#if UE_BUILD_SHIPPING
	return;
#endif
	UDataTable* dt = UBpGameplayHelperLib::GetAILookupDataTable();
	if (!dt)
		return;

	if (!GetPawn())
		return;

	const FVector SpawnLoc = GetPawn()->GetActorLocation() + (GetPawn()->GetActorForwardVector() * 200.0f);

	FAIDataLookupTable* AIData = dt->FindRow<FAIDataLookupTable>(*TableName, "Spawn AI Console Command");
	if (AIData)
	{
		for (int32 i = 0; i < Count; i++)
		{
			ACyberneticCharacter* SpawnedCharacter = GetWorld()->SpawnActor<ACyberneticCharacter>(AIData->CharacterClass, SpawnLoc, GetPawn()->GetActorRotation());
			if (SpawnedCharacter)
			{
				SpawnedCharacter->FinishAISpawning(nullptr, AIData);
			}
		}
	}
}

void AReadyOrNotPlayerController::StartMatchmaking()
{
#if defined(TARGET_PS5)
	UConsoleMultiplayerStatics::StartMatchMaking(GetWorld(),false);
#endif
}

void AReadyOrNotPlayerController::SpawnRandomAI(int32 Count /*= 1*/)
{
	UDataTable* dt = UBpGameplayHelperLib::GetAILookupDataTable();
	if (!dt)
		return;

	if (!GetPawn())
		return;

	const FVector SpawnLoc = GetPawn()->GetActorLocation() + (GetPawn()->GetActorForwardVector() * 200.0f);

	for (int32 i = 0; i < Count; i++)
	{
		FAIDataLookupTable* AIData = dt->FindRow<FAIDataLookupTable>(dt->GetRowNames()[FMath::RandRange(0, dt->GetRowNames().Num() - 1)], "Spawn AI Console Command");
		if (AIData)
		{
			ACyberneticCharacter* SpawnedCharacter = GetWorld()->SpawnActor<ACyberneticCharacter>(AIData->CharacterClass, SpawnLoc, GetPawn()->GetActorRotation());
			if (SpawnedCharacter)
			{
				SpawnedCharacter->FinishAISpawning(nullptr, AIData);
			}
		}
	}
}

void AReadyOrNotPlayerController::SpawnAIAtLocation(FString TableName, FVector Location, FVector MoveLocation)
{
	UDataTable* dt = UBpGameplayHelperLib::GetAILookupDataTable();
	if (!dt)
		return;

	FAIDataLookupTable* AIData = dt->FindRow<FAIDataLookupTable>(*TableName, "Spawn AI Console Command");
	if (AIData)
	{
		ACyberneticCharacter* SpawnedCharacter = GetWorld()->SpawnActor<ACyberneticCharacter>(AIData->CharacterClass, Location, GetPawn()->GetActorRotation());
		if (SpawnedCharacter)
		{
			SpawnedCharacter->FinishAISpawning(nullptr, AIData);
			UMoveActivity* MoveActivityInst = NewObject<UMoveActivity>(Cast<ACyberneticController>(SpawnedCharacter->GetController()), UMoveActivity::StaticClass());
			//MoveActivityInst->bAbortIfTrackingEnemy = true;

			if (const UNavigationSystemV1* NavSys = FNavigationSystem::GetCurrent<UNavigationSystemV1>(GetWorld()))
			{
				FNavLocation RandomPoint;
				NavSys->GetRandomReachablePointInRadius(MoveLocation, 500.0f, RandomPoint);

				// Deprecated function
				// UNavigationSystemV1::GetRandomReachablePointInRadius(GetWorld(), MoveLocation, 500.0f, nullptr, nullptr)
				
				MoveActivityInst->SetLocation(RandomPoint.Location);
			}
			
			Cast<ACyberneticController>(SpawnedCharacter->GetController())->AddActivity(MoveActivityInst, true);
		}
	}
}

void AReadyOrNotPlayerController::FlushDeadBodies()
{
	for (TActorIterator<AReadyOrNotCharacter> It(GetWorld()); It; ++It)
	{
		AReadyOrNotCharacter* RonCharacter = *It;
		
		if (RonCharacter->IsDeadOrUnconscious())
			RonCharacter->Destroy();
	}
}

void AReadyOrNotPlayerController::DestroyAllItems()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	for (TActorIterator<ABaseItem> It(GetWorld()); It; ++It)
	{
		ABaseItem* i = *It;
		
		if (Cast<ABaseMagazineWeapon>(i))
		 	continue;

		i->Destroy();
	}
}

void AReadyOrNotPlayerController::DestroyAllItemMeshes()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	for (TActorIterator<ABaseItem> It(GetWorld()); It; ++It)
	{
		ABaseItem* i = *It;
		TArray<USkeletalMeshComponent*> SkelMeshComps;
		i->GetComponents<USkeletalMeshComponent>(SkelMeshComps);
		for (USkeletalMeshComponent* skel : SkelMeshComps)
		{
			skel->SetSkeletalMesh(nullptr);
		}
	}
