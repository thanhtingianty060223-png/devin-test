void AReadyOrNotPlayerController::Client_CreateWidget_Implementation(const FString& WidgetName, bool bForceAddToWidgetStack, bool bIsEscapeKey)
{
	CreateWidgetForPlayer(WidgetName, bForceAddToWidgetStack, bIsEscapeKey);
}

UUserWidget* AReadyOrNotPlayerController::CreateWidgetForPlayer(const FString& WidgetName, bool bForceAddToWidgetStack, bool bIsEscapeKey)
{
	if (bIsEscapeKey)
	{
		UBpGameplayHelperLib::RemoveWidgetFromViewport("Escape");
	}
	
	bool bUsingGamepad = UReadyOrNotFunctionLibrary::IsUsingGamepad(this);

	FWidgetLookupData WidgetData;
	FString EffectiveName = WidgetName;
	if (bUsingGamepad)
	{
		FString GamepadWidgetName = WidgetName + "_Gamepad";
		WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(GamepadWidgetName, false);
		if (!WidgetData.WidgetClass)
			WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(WidgetName);
		else
			EffectiveName = GamepadWidgetName;
	}
	else
	{
		WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(WidgetName);
	}

	UUserWidget* WidgetInstance = nullptr;
	if (WidgetData.WidgetClass)
	{
		WidgetInstance = CreateWidget<UUserWidget>(GetWorld(), WidgetData.WidgetClass);
		if (WidgetInstance)
		{
			CreatedWidgetMap.Add(EffectiveName, WidgetInstance);
			int32 ZOrder = WidgetData.bShowMouseCursor ? WidgetStack.Num() : -1;
			if (WidgetName == "PermanentOverlay")
			{
				ZOrder = 1000;
			}
			WidgetInstance->AddToViewport(WidgetData.ZOrder > -1 ? WidgetData.ZOrder : ZOrder);
			
			if (WidgetName.Equals("Escape", ESearchCase::IgnoreCase))
			{
				UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
				bPreEscapeMenuMouseEnabled = gi->bForceShowMouseCursor;
			}

			if (WidgetInstance->bIsFocusable)
			{
				SetShouldShowMouseCursor(WidgetData.bShowMouseCursor);
				UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
				gi->bForceShowMouseCursor = WidgetData.bShowMouseCursor;
			}

			if (WidgetData.bAddToWidgetStack || bForceAddToWidgetStack)
			{
				WidgetStack.Add(EffectiveName);
			}

			if (auto *ActivatableWidget = Cast<UCommonActivatableWidget>(WidgetInstance))
				ActivatableWidget->ActivateWidget();

			if (bShouldShowMouseCursor)
            {
            	if (WidgetData.bMouseUIOnly)
            	{
            		ChangeInputMode(false, true, WidgetInstance);
            	}
            	else if (WidgetStack.Num() > 0)
            	{
            		// get top widget

            		UUserWidget* Widget = UBpGameplayHelperLib::GetFirstWidgetFromViewport(WidgetStack[0]);
            		if (Widget)
            		{
            			FWidgetLookupData LookupData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(WidgetStack[0]);
            			ChangeInputMode(false, LookupData.bShowMouseCursor && LookupData.bMouseUIOnly, Widget); 
            		}

            	}
				else if (WidgetStack.Num() == 0)
            	{
            		ChangeInputMode(false, false, WidgetInstance); 
            	}

				if (auto *MenuWidget = Cast<UMenuWidget>(WidgetInstance))
					MenuWidget->NativeOnShow();
            }
            else
            {
            	ChangeInputMode(true, false); 
            }
			
			WidgetInstance->SetVisibility(WidgetData.VisibilityUponCreation);
		}
	}

	UWidgetBlueprintLibrary::SetFocusToGameViewport();
	return WidgetInstance;
}

bool AReadyOrNotPlayerController::RemoveWidgetFromStack(const FString& WidgetName)
{
	if (WidgetStack.Num() <= 0)
		return false;
	
	if (WidgetStack.Top() == WidgetName)
	{
		EscapeMenu();
		return true;
	}

	if (WidgetStack.Contains(WidgetName) && CreatedWidgetMap.Contains(WidgetName))
	{
		UUserWidget* Widget = CreatedWidgetMap[WidgetName];
		if (IsValid(Widget))
			Widget->RemoveFromParent();
		
		CreatedWidgetMap.Remove(WidgetName);
		WidgetStack.Remove(WidgetName);
		return true;
	}
	return false;
}

void AReadyOrNotPlayerController::Client_CreateLoadingScreen_Implementation(const FString& Map, const FString& Mode, const FString& SessionName, bool bIsSeamlessTravel)
{
	UReadyOrNotStatics::GetReadyOrNotGameInstance()->bClientHasFinishedLoading = false;
	Client_ClearHUDWidgets();
	UpdateRichPresence(Map);
	UUserWidget* widget_instance = CreateWidget<UUserWidget>(UReadyOrNotStatics::GetReadyOrNotGameInstance(), UBpGameplayHelperLib::GetWidgetDataFromLookupData("LoadingScreen").WidgetClass);
	if (widget_instance)
		widget_instance->AddToViewport(MAX_int32);
	ULoadingScreen* LoadingScreen = Cast<ULoadingScreen>(widget_instance);
	if (LoadingScreen)
	{
		LoadingScreen->SetLoadingScreen(Map, Mode, SessionName, bIsSeamlessTravel);
		LoadingScreen->SetKeyboardFocus();
	}
}

void AReadyOrNotPlayerController::CreateSessionLoadingScreen(FBlueprintSessionResult SessionSearchResult)
{
	UReadyOrNotStatics::GetReadyOrNotGameInstance()->bClientHasFinishedLoading = false;
	Client_ClearHUDWidgets();
	UUserWidget* widget_instance = CreateWidget<UUserWidget>(UReadyOrNotStatics::GetReadyOrNotGameInstance(), UBpGameplayHelperLib::GetWidgetDataFromLookupData("LoadingScreen").WidgetClass);
	if (widget_instance)
		widget_instance->AddToViewport(MAX_int32);
	ULoadingScreen* LoadingScreen = Cast<ULoadingScreen>(widget_instance);
	if (LoadingScreen)

	{
		FString Map, GameMode, SessionName;
		SessionSearchResult.OnlineResult.Session.SessionSettings.Get(SETTING_MAPNAME, Map);
		SessionSearchResult.OnlineResult.Session.SessionSettings.Get(SETTING_GAMEMODE, GameMode);
		SessionSearchResult.OnlineResult.Session.SessionSettings.Get(SETTING_GAMENAME, SessionName);
		LoadingScreen->SetLoadingScreen(Map, GameMode, SessionName, false);
	}
}

void AReadyOrNotPlayerController::RecreateOverlays()
{
	if (!UBpGameplayHelperLib::HasWidgetInViewport("DebugOverlay"))
	{
		Client_CreateWidget("DebugOverlay");
	}
	if (!UBpGameplayHelperLib::HasWidgetInViewport("PermanentOverlay"))
	{
		Client_CreateWidget("PermanentOverlay");
	}
}

void AReadyOrNotPlayerController::Server_RespawnAsLobby_Implementation(TSubclassOf<ASpectatorPawn> Class, FTransform SpawnTransform)
{
	AActor* startPoint = nullptr;

	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		for (TActorIterator<APlayerStart> It(GetWorld()); It; ++It)
		{
			APlayerStart* start = *It;
			if (start)
			{
				if (start->PlayerStartTag == gm->LobbyStartTag)
				{
					startPoint = start;
				}
			}
		}
		if (startPoint)
		{
			FTransform useTransform;
			if (SpawnTransform.GetLocation() == FVector::ZeroVector && SpawnTransform.GetRotation().Rotator() == FRotator::ZeroRotator)
			{
				useTransform = startPoint->GetActorTransform();
			}
			else
			{
				useTransform = SpawnTransform;
			}
			ASpectatorPawn* spectatePawn = gm->SpawnSpectator(this, Class, useTransform);
			if (spectatePawn)
			{
				Client_SetControlRotation(useTransform.GetRotation().Rotator());
				Client_SetViewTargetWithBlend(spectatePawn);
			}
		}
	}

}

void AReadyOrNotPlayerController::Client_DisableUIMouse_Implementation()
{
	while (WidgetStack.Num() > 0)
	{
		FWidgetLookupData WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(WidgetStack[0]);
		if (!WidgetData.bCloseOnRespawn)
		{
			return;
		}
		else
		{
			UBpGameplayHelperLib::RemoveWidgetFromViewport(WidgetStack[0]);
			WidgetStack.RemoveAt(0);
		}
	}

	DisableForceShowMouseCursor();
	SetShouldShowMouseCursor(false);
	bEnableClickEvents = false;
	bEnableMouseOverEvents = false;
	ChangeInputMode(true, false);
}

void AReadyOrNotPlayerController::Client_SetControlRotation_Implementation(FRotator NewControlRotation)
{
	SetControlRotation(NewControlRotation);
}

void AReadyOrNotPlayerController::Client_SetViewTargetWithBlend_Implementation(APawn* NewViewTarget)
{
	if (NewViewTarget)
	{ 
		float BlendTime = 0.0f;
		if (Cast<APlayerCharacter>(NewViewTarget))
		{
			BlendTime = 0.0f;
		}
		else if (Cast<ASpectatorPawn>(NewViewTarget))
		{
			ASpectatePawn* spectatePawn = Cast<ASpectatePawn>(NewViewTarget);
			if (spectatePawn)
			{
				if (spectatePawn->bBlendWithViewTarget)
					BlendTime = 1.5f;
			}
			else
			{
				BlendTime = 0.0f;
			}
		}
		SetViewTargetWithBlend(NewViewTarget, BlendTime, EViewTargetBlendFunction::VTBlend_Cubic, BlendTime, true);
	}
}

void AReadyOrNotPlayerController::Server_BecomeVIP_Implementation()
{
	AVIPEscortGM* gm = Cast<AVIPEscortGM>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		
		if (gm->VIPPlayer)
		{
			AReadyOrNotPlayerState* vipPS = Cast<AReadyOrNotPlayerState>(gm->VIPPlayer->PlayerState);
			if (vipPS)
			{
				vipPS->bIsVIP = false;
			}
		}
		gm->VIPPlayer = this;

		AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
		if (ps)
		{
			ps->bIsVIP = true;
		}
	}
}

void AReadyOrNotPlayerController::ReleaseVIP()
{
	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps)
	{
		FSavedLoadout defaultLoadout;
		UBpGameplayHelperLib::LoadLoadout(defaultLoadout, "default");
		ps->Server_SetLoadout(defaultLoadout);
		ps->LastLoadout = defaultLoadout;
	}
	Server_ReleaseVIP();
}

void AReadyOrNotPlayerController::Server_ReleaseVIP_Implementation()
{
	AVIPEscortGM* gm = Cast<AVIPEscortGM>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		if (gm->VIPPlayer == this)
		{
			if (Cast<AReadyOrNotPlayerState>(PlayerState))
			{
				Cast<AReadyOrNotPlayerState>(PlayerState)->bIsVIP = false;
			}
			gm->VIPPlayer = nullptr;
		}
	}
}

