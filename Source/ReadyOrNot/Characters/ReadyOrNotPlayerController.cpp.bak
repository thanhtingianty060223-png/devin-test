 void AReadyOrNotPlayerController::ReplicateMapListIfAdmin()
 {
	 AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	 if (gm)
	 {
		 AReadyOrNotGameSession* gs = gm->GetReadyOrNotGameSession();
