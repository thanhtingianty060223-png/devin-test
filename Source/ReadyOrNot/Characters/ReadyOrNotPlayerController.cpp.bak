void AReadyOrNotPlayerController::PS5ActivityEnd(FString& Activity, int Outcome)
{
#if defined(TARGET_PS5)
	EOnlineActivityOutcome OutcomeE;
	if (Outcome == 0)
		OutcomeE = EOnlineActivityOutcome::Completed;
	if (Outcome == 1)
		OutcomeE = EOnlineActivityOutcome::Failed;
	if (Outcome == 2)
		OutcomeE = EOnlineActivityOutcome::Cancelled;
		
	UPS5ActivitiesStatics::ActivityEnd(GetWorld(), Activity, OutcomeE);
#endif
}

