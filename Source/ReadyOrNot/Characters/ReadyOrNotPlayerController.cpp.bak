void AReadyOrNotPlayerController::OnLocallyFiredProjectile(ABulletProjectile* Projectile, int32 ProjectileIdentifier)
{
	if (!IsValid(Projectile))
		return;

	FProjectileData* ExistingData = ActiveProjectiles.Find(ProjectileIdentifier);
	if(!ExistingData)
	{
		FProjectileData ProjectileData;
		ProjectileData.Projectiles = { Projectile };

		ActiveProjectiles.Emplace(ProjectileIdentifier, ProjectileData);
	}
	else
	{
		ExistingData->Projectiles.Emplace(Projectile);
	}
}

void AReadyOrNotPlayerController::Client_OnProjectileValidation_Implementation(int32 ProjectileSeed, EServerValidationState Validation)
{
	if (!ActiveProjectiles.Find(ProjectileSeed))
		return;
	
	TArray<ABulletProjectile*>& Projectiles = ActiveProjectiles[ProjectileSeed].Projectiles;
	
	switch(Validation)
	{
		case EServerValidationState::Invalid:
			for (int32 i = 0; i < Projectiles.Num(); i++)
			{
				if (!IsValid(Projectiles[i]))
					continue;
				
				Projectiles[i]->Destroy();			
			}
			ActiveProjectiles.Remove(ProjectileSeed);
			break;
		
		case EServerValidationState::Validated:
			for (int32 i = 0; i < Projectiles.Num(); i++)
			{
				if (!IsValid(Projectiles[i]))
					continue;
				
				Projectiles[i]->OnProjectileValidated();				
			}
			ActiveProjectiles.Remove(ProjectileSeed);
			break;
		
		case EServerValidationState::Unvalidated:
		default:
			break;	
	}
}

void AReadyOrNotPlayerController::ReadyUp()
{
	AMissionPortal* MissionPortal = nullptr;
	for (TActorIterator<AMissionPortal> It(GetWorld()); It; ++It)
	{
		MissionPortal = *It;
		break;
	}

	// No use for ready up if there's no mission portal
	if (!IsValid(MissionPortal))
		return;

	// Make sure that a mission has been selected before allowing ready up
	if (MissionPortal->MissionURL.IsEmpty())
		return;
	
	bIsReady = !bIsReady;

	Server_SetReadyState(bIsReady);
	
	if (!HasAuthority())
	{
		// Run it locally and then again when server responds to update if it's wrong for whatever reason
		Client_LocalReadyStateChanged(bIsReady);		
	}
}

void AReadyOrNotPlayerController::ReadyUp_Failsafe()
{
	const FKey BoundReadyUpKey = UReadyOrNotFunctionLibrary::GetKeyFromInputActionName("ReadyUp");
	if (!BoundReadyUpKey.IsValid())
	{
		ReadyUp();
	}
}

void AReadyOrNotPlayerController::Server_SetReadyState_Implementation(bool bReady)
{
	bIsReady = bReady;
	OnPlayerReadyChange.Broadcast(this, bIsReady);
	Client_LocalReadyStateChanged(bIsReady);
}

void AReadyOrNotPlayerController::Client_LocalReadyStateChanged_Implementation(bool bReady)
{
	const APlayerCharacter* PlayerCharacter = Cast<APlayerCharacter>(GetPawn());
	if (!PlayerCharacter || !IsValid(PlayerCharacter->HumanCharacterWidget_V2))
		return;
	
	PlayerCharacter->HumanCharacterWidget_V2->LocalReadyStateChanged(bIsReady);
}

void AReadyOrNotPlayerController::Client_UpdateWorldTime_Implementation(float ServerTime, float SentClientTime)
{
	if (!GetWorld() || RoundTripTimeBuffer.Num() <= 0)
		return;
	
	const float RoundTripTime = GetWorld()->GetTimeSeconds() - SentClientTime;
	float AdjustedRoundTripTime = RoundTripTime;

	RoundTripTimeBuffer[RoundTripTimeBufferIndex] = RoundTripTime;
	RoundTripTimeBufferIndex++;

	if (RoundTripTimeBufferIndex >= RoundTripTimeBuffer.Num())
		RoundTripTimeBufferIndex = 0;
	
	if (!RoundTripTimeBuffer.Contains(-1.0f))
	{
		float ShortestTime = FLT_MAX;
		float LongestTime = -FLT_MAX;

		for (int32 i = 0; i < RoundTripTimeBuffer.Num() - 1; i++)
		{
			float Time = RoundTripTimeBuffer[i];
			
			if (Time > LongestTime)
				LongestTime = Time;
			
			if (Time < ShortestTime)
				ShortestTime = Time;
		}

		int32 Samples = 0;
		for (int32 i = 0; i < RoundTripTimeBuffer.Num() - 1; i++)
		{
			float Time = RoundTripTimeBuffer[i];

			if (Time <= ShortestTime)
			{
				ShortestTime = -FLT_MAX;
				continue;
			}
			if (Time >= LongestTime)
			{
				LongestTime = FLT_MAX;
				continue;
			}
			
			AdjustedRoundTripTime += Time;
			Samples++;
		}

		AdjustedRoundTripTime /= Samples;
	}

	ServerTimeDelta = ServerTime - SentClientTime - (AdjustedRoundTripTime / 2.0f);
	if (FMath::Abs(ServerTimeDelta) > 10000.0f)
	{
		GEngine->AddOnScreenDebugMessage(-1, 0.0f, FColor::Red, TEXT("FRICK"));
		return;
	}
}

void AReadyOrNotPlayerController::Server_RequestWorldTime_Implementation(float ClientTime)
{
	if (!GetWorld())
		return;

	const float ServerTime = GetWorld()->GetTimeSeconds();
	Client_UpdateWorldTime(ServerTime, ClientTime);
}

void AReadyOrNotPlayerController::PostNetInit()
{
	Super::PostNetInit();
	
	constexpr int32 RoundTripBufferSize = 10;
	
	RoundTripTimeBuffer.Init(-1.0f, RoundTripBufferSize);
	RoundTripTimeBufferIndex = 0;

	ServerTimeDelta = 0.0f;

	if (GetLocalRole() != ROLE_Authority)
	{
		Server_RequestWorldTime(GetWorld()->GetTimeSeconds());

		FTimerDelegate TimerDelegate = FTimerDelegate::CreateWeakLambda(this, [&]()
		{
			Server_RequestWorldTime(GetWorld()->GetTimeSeconds());
		});
		
		FTimerHandle TimerHandle;
		GetWorld()->GetTimerManager().SetTimer(TimerHandle, TimerDelegate, 1.0f, true);
	}
}

float AReadyOrNotPlayerController::GetSynchronizedWorldTime() const
{
	if (!GetWorld())
		return 0.0f;
	
	return GetWorld()->GetTimeSeconds() + ServerTimeDelta; 
}

void AReadyOrNotPlayerController::SetAimDownSightsAimAssist(bool Enable)
{
	SetActiveAimAssistConfig(GetAimAssistConfigByIntensity(AimAssistIntensity, Enable));
}

UUASAimAssistConfigDataAsset* AReadyOrNotPlayerController::GetAimAssistConfigByIntensity(
	const FString& Intensity, bool bAds)
{
	if (bAds)
	{
		if (Intensity.Equals("high"))
		{
			return AimAssistConfigADS_High;
		}
		if (Intensity.Equals("medium"))
		{
			return AimAssistConfigADS_Medium;
		}
		if (Intensity.Equals("low"))
		{
			return AimAssistConfigADS_Low;
		}
		if (Intensity.Equals("off"))
		{
			return AimAssistConfigADS_Off;
		}
	}
	else
	{
		if (Intensity.Equals("high"))
		{
			return AimAssistConfig_High;
		}
		if (Intensity.Equals("medium"))
		{
			return AimAssistConfig_Medium;
		}
		if (Intensity.Equals("low"))
		{
			return AimAssistConfig_Low;
		}
		if (Intensity.Equals("off"))
		{
			return AimAssistConfig_Off;
		}
	}
	return nullptr;
}

void AReadyOrNotPlayerController::SetActiveAimAssistConfig(UUASAimAssistConfigDataAsset* NewAimAssistConfig)
{
	TArray<UUASAimAssistComponent*> AimAssistComponents;
	GetComponents<UUASAimAssistComponent>(AimAssistComponents);
	for (UUASAimAssistComponent* AimAssistComponent : AimAssistComponents)
	{
		AimAssistComponent->SetAimAssistDataAsset(NewAimAssistConfig);
		AimAssistComponent->SetEnableStickiness(NewAimAssistConfig->EnableStickiness);
		AimAssistComponent->SetEnableMagnetism(NewAimAssistConfig->EnableMagnetism);
		AimAssistComponent->SetEnableZoneScaling(NewAimAssistConfig->EnableZoneScaling);
		AimAssistComponent->SetEnableAutoAim(NewAimAssistConfig->EnableAutoAim);
	}
}

void AReadyOrNotPlayerController::LoadAimAssistIntensity()
{
	FString NewAimAssistIntensity;
	if (UBpGameplayHelperLib::GetGamepadAimAssistIntensity(NewAimAssistIntensity))
	{
		AimAssistIntensity = NewAimAssistIntensity;
	}
}
