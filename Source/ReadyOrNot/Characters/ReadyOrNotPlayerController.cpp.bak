void AReadyOrNotPlayerController::SetRosterStressValue(float Stress)
{
	if (!GetWorld())
		return;
	
	ALobbyGM* LobbyGM = GetWorld()->GetAuthGameMode<ALobbyGM>();
	if (!LobbyGM || !LobbyGM->RosterManager)
		return;

	URosterManager* RosterManager = LobbyGM->RosterManager;
	for (URosterCharacter* RosterCharacter : RosterManager->GetAllCharacters())
	{
		RosterCharacter->StressLevel = Stress;
	}

	URosterSelectionWidget::UpdateAllRosterWidgets(GetWorld());
}

void AReadyOrNotPlayerController::RosterInstantFinishStatus()
{
	if (!GetWorld())
		return;
	
	ALobbyGM* LobbyGM = GetWorld()->GetAuthGameMode<ALobbyGM>();
	if (!LobbyGM || !LobbyGM->RosterManager)
		return;

	URosterManager* RosterManager = LobbyGM->RosterManager;
	for (URosterCharacter* RosterCharacter : RosterManager->GetAllCharacters())
	{
		if (RosterCharacter->State == ERosterCharacterState::InTherapy)
			RosterCharacter->StressLevel = 0.0f;
		
		RosterCharacter->State = ERosterCharacterState::Available;
		RosterCharacter->MissionsUntilReturn = 0;
	}

	URosterSelectionWidget::UpdateAllRosterWidgets(GetWorld());
}

void AReadyOrNotPlayerController::SetTimelimit(float NewTime)
{
	AReadyOrNotGameMode* gm = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();
	if (!gm)
	{
		return;
	}
	AReadyOrNotGameSession* Session = gm->GetReadyOrNotGameSession();
	if (!Session)
	{
		return;
	}

	Session->SetServerSettings(Session->RoundTimerGameStart, Session->RoundTimerBetweenMaps, Session->ReinforcementTimer, NewTime, Session->RoundsPerMap, Session->Scorelimit);
	AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
	if (!gs)
	{
		return;
	}
	gs->ResetReplicatedTimers();
}

void AReadyOrNotPlayerController::SetScorelimit(int32 NewScorelimit)
{
	AReadyOrNotGameMode* gm = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();
	if (!gm)
	{
		return;
	}
	AReadyOrNotGameSession* Session = gm->GetReadyOrNotGameSession();
	if (!Session)
	{
		return;
	}

	Session->SetServerSettings(Session->RoundTimerGameStart, Session->RoundTimerBetweenMaps, Session->ReinforcementTimer, Session->Timelimit, Session->RoundsPerMap, NewScorelimit);
	AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
	if (!gs)
	{
		return;
	}
	gs->ResetReplicatedTimers();
}

void AReadyOrNotPlayerController::DeleteAnyNonMeshComponents()
{
	for (TActorIterator<APlayerCharacter> It(GetWorld()); It; ++It)
	{
		APlayerCharacter* pc = *It;
		TArray<UActorComponent*> ActorComponents;
		pc->GetComponents(ActorComponents);
		for (UActorComponent* a : ActorComponents)
		{
			if (a != pc->GetMesh()
				&& a != pc->GetCapsuleComponent()
				&& a != pc->GetMesh1P()
				&& a != pc->GetMeshBody()
				&& a != pc->GetFaceMesh()
				&& a != pc->GetFirstPersonCameraComponent()
				&& a != pc->GetCharacterMovement())
			{
				a->DestroyComponent();
			}
		}
		
	}

	for (TActorIterator<ABaseItem> It(GetWorld()); It; ++It)
	{
		ABaseItem* bi = *It;
		TArray<UActorComponent*> ActorComponents;
		bi->GetComponents(ActorComponents);
		for (UActorComponent* a : ActorComponents)
		{
			if (a != bi->GetItemMesh()
				&& a != bi->GetRootComponent())
			{
				a->DestroyComponent();
			}
			
		}
	}
}

void AReadyOrNotPlayerController::SetAllComponentsUseParentsBounds()
{
	for (TActorIterator<APlayerCharacter> It(GetWorld()); It; ++It)
	{
		APlayerCharacter* pc = *It;
		TArray<USceneComponent*> ActorComponents;
		pc->GetComponents(ActorComponents);
		for (USceneComponent* a : ActorComponents)
		{
			a->bUseAttachParentBound = true;
		}
		
	}

	for (TActorIterator<ABaseItem> It(GetWorld()); It; ++It)
	{
		ABaseItem* bi = *It;
		TArray<USceneComponent*> ActorComponents;
		bi->GetComponents(ActorComponents);
		for (USceneComponent* a : ActorComponents)
		{
			a->bUseAttachParentBound = true;			
		}
	}
}

