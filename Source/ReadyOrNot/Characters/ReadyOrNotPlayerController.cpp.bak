void AReadyOrNotPlayerController::ResetAI(float Range)
{
#if UE_BUILD_SHIPPING
	return;
#endif
	for (TActorIterator<ACyberneticCharacter>It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* CyberneticCharacter = *It;
		CyberneticCharacter->Destroy();
	}

	ACoopGM* CoopGM = Cast<ACoopGM>(GetWorld()->GetAuthGameMode());
	if (CoopGM)
	{
		for (TActorIterator<AAISpawn> It(GetWorld()); It; ++It)
		{
			AAISpawn* Spawner = *It;
			float Dist = (GetPawnOrSpectator()->GetActorLocation() - Spawner->GetActorLocation()).Size();
			if (Dist < Range)
			{
				Spawner->DoSpawn();
			}
		}
		//CoopGM->SpawnSuspectsAndHostages();
		//CoopGM->SpawnPolice();
	}
}

