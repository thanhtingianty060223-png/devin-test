void AReadyOrNotPlayerController::ApplyWeaponSkin(FString SkinName)
{
#if UE_BUILD_SHIPPING
	return;
#endif
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;

	if (!pc->GetEquippedItem())
		return;

	for (TObjectIterator<UClass> It; It; ++It)
	{
	UClass* ItrClass = *It;
	if (!ItrClass)
		continue;

	if (!It->HasAnyClassFlags(CLASS_Abstract))
	{
		if (It->GetName().Contains(SkinName))
		{
			if (It->IsChildOf(USkinComponent::StaticClass()))
			{
				USkinComponent* SkinComp = NewObject<USkinComponent>(pc->GetEquippedItem(), *It);
				if (SkinComp)
				{
					SkinComp->RegisterComponent();
					break;
				}
			}
		}
	}
	}
}

void AReadyOrNotPlayerController::RemoveWeaponSkin()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;

	if (!pc->GetEquippedItem())
		return;

	TArray<USkinComponent*> SkinComps;
	pc->GetEquippedItem()->GetComponents(SkinComps);
	for (int32 i = 0; i < SkinComps.Num(); i++)
	{
		USkinComponent* SkinComp = SkinComps[i];
		if (SkinComp)
		{
			SkinComp->ResetSkin();
			SkinComp->DestroyComponent();
		}
	}
}

void AReadyOrNotPlayerController::ApplyCharacterSkin(FString SkinName)
{
#if UE_BUILD_SHIPPING
	return;
#endif
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;

	for (TObjectIterator<UClass> It; It; ++It)
	{
		UClass* ItrClass = *It;
		if (!ItrClass)
			continue;

		if (!It->HasAnyClassFlags(CLASS_Abstract))
		{
			if (It->GetName().Contains(SkinName))
			{
				if (It->IsChildOf(USkinComponent::StaticClass()))
				{
					USkinComponent* SkinComp = NewObject<USkinComponent>(pc, *It);
					if (SkinComp)
					{
						SkinComp->RegisterComponent();
						break;
					}
				}
			}
		}
	}
}

void AReadyOrNotPlayerController::RemoveCharacterSkin()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;

	TArray<USkinComponent*> SkinComps;
	pc->GetComponents(SkinComps);
	for (int32 i = 0; i < SkinComps.Num(); i++)
	{
		USkinComponent* SkinComp = SkinComps[i];
		if (SkinComp)
		{
			SkinComp->ResetSkin();
			SkinComp->DestroyComponent();
		}
	}
}

void AReadyOrNotPlayerController::GiveSWATRam()
{
#if UE_BUILD_SHIPPING
