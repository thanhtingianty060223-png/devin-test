void AReadyOrNotPlayerController::PawnPendingDestroy(APawn* inPawn)
{
	LastDeathLocation = inPawn->GetActorLocation();
	FVector CameraLocation = LastDeathLocation + FVector(0, 0, 300.0f);
	FRotator CameraRotation(-90.0f, 0.0f, 0.0f);
	FindDeathCameraSpot(CameraLocation, CameraRotation);

	Super::PawnPendingDestroy(inPawn);

	ClientSetSpectatorCamera(CameraLocation, CameraRotation);
}

bool AReadyOrNotPlayerController::FindDeathCameraSpot(FVector& CameraLocation, FRotator& CameraRotation)
{
	const FVector PawnLocation = GetPawn()->GetActorLocation();
	FRotator ViewDir = GetControlRotation();
	ViewDir.Pitch = -45.0f;

	const float YawOffsets[] = { 0.0f, -180.0f, 90.0f, -90.0f, 45.0f, -45.0f, 135.0f, -135.0f };
	const float CameraOffset = 600.0f;
	FCollisionQueryParams TraceParams(TEXT("DeathCamera"), true, GetPawn());

	FHitResult HitResult;
	for (int32 i = 0; i < UE_ARRAY_COUNT(YawOffsets); i++)
	{
		FRotator CameraDir = ViewDir;
		CameraDir.Yaw += YawOffsets[i];
		CameraDir.Normalize();

		const FVector TestLocation = PawnLocation - CameraDir.Vector() * CameraOffset;

		const bool bBlocked = GetWorld()->LineTraceSingleByChannel(HitResult, PawnLocation, TestLocation, ECC_Camera, TraceParams);

		if (!bBlocked)
		{
			CameraLocation = TestLocation;
			CameraRotation = CameraDir;
			return true;
		}
	}

	return false;
}

void AReadyOrNotPlayerController::ClientTravelInternal_Implementation(const FString& URL, ETravelType TravelType, bool bSeamless, FGuid MapPackageGuid)
{
	UWorld* World = GetWorld();

	FString newURL = URL;
	newURL += "?password=" + GetPasswordOnConnection();

	newURL += "?teamuniqueid=" + GetPrefferredTeamUniqueNetIdOnConnection();

	// Warn the client.
	PreClientTravel(newURL, TravelType, bSeamless);
	StopSpeaking();
	IOnlineVoicePtr VoiceInterface = Online::GetVoiceInterface();
	if (VoiceInterface.Get())
	{
		VoiceInterface->RemoveAllRemoteTalkers();
	}
	UVOIPStatics::ClearAllSettings();

	for (TObjectIterator<USynthComponent>It; It; ++It)
	{
		It->Stop();
	}
	if (bSeamless && TravelType == TRAVEL_Relative)
	{
		World->SeamlessTravel(newURL);
	}
	else
	{
		if (bSeamless)
		{
			UE_LOG(LogReadyOrNot, Warning, TEXT("Unable to perform seamless travel because TravelType was %i, not TRAVEL_Relative"), int32(TravelType));
		}
		// Do the travel.
		GEngine->SetClientTravel(World, *newURL, (ETravelType)TravelType);
	}
}

void AReadyOrNotPlayerController::PreClientTravel(const FString& PendingURL, ETravelType TravelType,
	bool bIsSeamlessTravel)
{

	OnPreClientTravel.Broadcast();
	Super::PreClientTravel(PendingURL, TravelType, bIsSeamlessTravel);
	FString OutL, Options, Mode, NA, MapName;
	PendingURL.Split("?", &OutL, &Options);
	PendingURL.Split("?Game=", &NA, &Mode);
	OutL.Split("/", &NA, &MapName, ESearchCase::IgnoreCase, ESearchDir::FromEnd);
	ULevelStreaming* OutStreamedLevel;
	FLevelStreamOptions LevelStreamOptions;
	LevelStreamOptions.bExecuteOpenLevelWhenLoaded = false;
	LevelStreamOptions.bShouldRemoveLoadingScreen = false;
	LevelStreamOptions.bIsSeamlessTravel = bIsSeamlessTravel;
	IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
	if (OnlineSub)
	{
		IOnlineSessionPtr SessionInt = Online::GetSessionInterface();
		if (SessionInt)
		{
			#if defined(WITH_STEAM) || defined(USE_EOS) || defined(TARGET_CONSOLE)
				#if defined(TARGET_PS5)
					FNamedOnlineSession* Session = SessionInt->GetNamedSession(NAME_PartySession);
				#else
					FNamedOnlineSession* Session = SessionInt->GetNamedSession(NAME_GameSession);
				#endif
			if (Session != nullptr)
			{
				Session->SessionSettings.Get(SETTING_GAMENAME, LevelStreamOptions.SessionName);
			}
			#endif
		}
	}
	if (LevelStreamOptions.ModeName.IsEmpty())
	{
		FString LeftSplit, RightSplit;
		Mode.Split("?", &LeftSplit, &RightSplit);
		LevelStreamOptions.ModeName = LeftSplit.IsEmpty() ? Mode : LeftSplit;
	}

#if defined(TARGET_CONSOLE) || defined(USE_EOS)
	if (MapName.IsEmpty()) {
		MapName = StreamingLevel;
	}
#endif

	StreamInLevel(MapName, Options, OutStreamedLevel, LevelStreamOptions);
}

void AReadyOrNotPlayerController::BP_ReturnToMenu(const FText& ReturnReason)
{
	UGameplayStatics::SetGamePaused(this, false);
	UReadyOrNotFunctionLibrary::PauseFMOD(false);

	ClientReturnToMainMenuWithTextReason(ReturnReason);
}

void AReadyOrNotPlayerController::ClientReturnToMainMenuWithTextReason(const FText& ReturnReason)
{
	// set the return to menu reason if any
	UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
	if (gi)
	{
		if (gi->MainMenuDisplayMessage.IsEmpty())
		{
			gi->MainMenuDisplayMessage = ReturnReason.ToString();
		}
	}

	// destroy the session if valid
	IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
	if (OnlineSub)
	{
		IOnlineSessionPtr Sessions = OnlineSub->GetSessionInterface();
		if (Sessions.IsValid() && (Sessions->GetNamedSession(GameSessionName) != nullptr))
		{
			// Note this is async, it could possibly be a problem that is does not await that the session is confirmed destroyed.
			Sessions->DestroySession(GameSessionName);
		}
	}

	UReadyOrNotStatics::GetReadyOrNotGameInstance()->LeaveVoiceChannels();

	ULevelStreaming* OutStreamedLevel;
	FLevelStreamOptions LevelStreamOptions;
	LevelStreamOptions.bStreamInLevelBeforeLoad = true;
	StreamInLevel("MainMenu_V2", "", OutStreamedLevel, LevelStreamOptions);
}

void AReadyOrNotPlayerController::GetNetworkConnectionStatus(float& AvgLag, int32& OutLostPackets, int32& InLostPackets, int32& OutLostPacketPrcnt, int32& InLostPacketPrcnt)
{
	if (GetNetConnection())
	{
		AvgLag = GetNetConnection()->AvgLag;
		OutLostPackets = GetNetConnection()->OutPacketsLost;
		InLostPackets = GetNetConnection()->InPacketsLost;
		OutLostPacketPrcnt = GetNetConnection()->GetOutLossPercentage().GetAvgLossPercentage()*100;
		InLostPacketPrcnt = GetNetConnection()->GetOutLossPercentage().GetAvgLossPercentage()*100;
	}
	
}

