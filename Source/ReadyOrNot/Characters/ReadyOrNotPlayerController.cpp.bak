void AReadyOrNotPlayerController::Server_LoginAsAdmin_Implementation(const FString& password)
{
	
	// only allow admins to login on a dedicated server.. on a listen server the host is always the admin
	if (!UKismetSystemLibrary::IsDedicatedServer(GetWorld()))
	   return;

	if (password.IsEmpty())
		return;
	   
	AReadyOrNotGameSession* Session = Cast<AReadyOrNotGameSession>(GetWorld()->GetAuthGameMode()->GameSession);
	if (Session)
	{		
		if (Session->AdminPassword.Equals(password))
		{
			Session->AddAdmin(this);
		}
	}
}

