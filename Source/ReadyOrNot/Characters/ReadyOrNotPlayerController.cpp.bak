void AReadyOrNotPlayerController::SpawnBotsForGame(int32 BotCount)
{
#if UE_BUILD_SHIPPING
	return;
#endif
	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (!gm)
		return;
	
	FActorSpawnParameters SpawnParams;
	SpawnParams.SpawnCollisionHandlingOverride = ESpawnActorCollisionHandlingMethod::AdjustIfPossibleButAlwaysSpawn;
	SpawnParams.bNoFail = true;
	FTransform SpawnTransform = FTransform();
	for (int32 i = 0; i < BotCount * 0.5f; i++ )
	{
		SpawnTransform.SetScale3D(FVector(1.0f));

		FActorSpawnParameters SpawnInfo;
		SpawnInfo.Instigator = GetInstigator();
		SpawnInfo.SpawnCollisionHandlingOverride = ESpawnActorCollisionHandlingMethod::AlwaysSpawn;
		SpawnInfo.OverrideLevel = GetLevel();
		SpawnInfo.ObjectFlags |= RF_Transient;	// We never want to save AI controllers into a map
		AController* NewController = GetWorld()->SpawnActor<AController>(ACyberneticController::StaticClass(), FTransform(), SpawnInfo);
		if (NewController != nullptr)
		{
			AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(NewController->PlayerState);
			if (ps)
			{
				// Set loadout
				FSavedLoadout Loadout;
				UBpGameplayHelperLib::LoadLoadout(Loadout, "default");
				//UWorld* World = GetWorld();
				ps->SetPlayerName("Blue Bot #" + FString::FromInt(i));
				ps->Server_SetLoadout(Loadout);
				ps->bSpawnLoadout = true;
				ps->SetTeam(ETeamType::TT_SERT_BLUE);
			}
			
			AActor* Start = gm->FindPlayerStart(NewController);
			if (Start)
			{
				APlayerCharacter* bot = GetWorld()->SpawnActor<APlayerCharacter>(gm->BlueCharacterClass.LoadSynchronous(), Start->GetActorTransform(), SpawnParams);
				if (bot)
				{
					bot->GetCharacterMovement()->RotationRate = FRotator::ZeroRotator;
					NewController->Possess(bot);

					bot->OnCharacterKilled.RemoveDynamic(gm, &AReadyOrNotGameMode::PlayerKilled);
					bot->OnCharacterKilled.AddDynamic(gm, &AReadyOrNotGameMode::PlayerKilled);
					bot->OnPlayerArrested.RemoveDynamic(gm, &AReadyOrNotGameMode::PlayerArrested);
					bot->OnPlayerArrested.AddDynamic(gm, &AReadyOrNotGameMode::PlayerArrested);
					bot->OnCharacterTakeDamage.RemoveDynamic(gm, &AReadyOrNotGameMode::PlayerTakenDamage);
					bot->OnCharacterTakeDamage.AddDynamic(gm, &AReadyOrNotGameMode::PlayerTakenDamage);
					bot->OnPlayerFreed.RemoveDynamic(gm, &AReadyOrNotGameMode::PlayerFreed);
					bot->OnPlayerFreed.AddDynamic(gm, &AReadyOrNotGameMode::PlayerFreed);
					
				}
			}
		}
	}
	for (int32 i = 0; i < BotCount * 0.5f; i++ )
	{
		SpawnTransform.SetScale3D(FVector(1.0f));

		FActorSpawnParameters SpawnInfo;
		SpawnInfo.Instigator = GetInstigator();
		SpawnInfo.SpawnCollisionHandlingOverride = ESpawnActorCollisionHandlingMethod::AlwaysSpawn;
		SpawnInfo.OverrideLevel = GetLevel();
		SpawnInfo.ObjectFlags |= RF_Transient;	// We never want to save AI controllers into a map
		AController* NewController = GetWorld()->SpawnActor<AController>(ACyberneticController::StaticClass(), FTransform(), SpawnInfo);
		if (NewController != nullptr)
		{
			AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(NewController->PlayerState);
			if (ps)
			{
				// Set loadout
				FSavedLoadout Loadout;
				UBpGameplayHelperLib::LoadLoadout(Loadout, "default");
				//UWorld* World = GetWorld();
				ps->SetPlayerName("Red Bot #" + FString::FromInt(i));
				ps->Server_SetLoadout(Loadout);
				ps->bSpawnLoadout = true;
				ps->SetTeam(ETeamType::TT_SERT_RED);
			}
			
			AActor* Start = gm->FindPlayerStart(NewController);
			if (Start)
			{
				APlayerCharacter* bot = GetWorld()->SpawnActor<APlayerCharacter>(gm->RedCharacterClass.LoadSynchronous(), Start->GetActorTransform(), SpawnParams);
				if (bot)
				{
					bot->GetCharacterMovement()->RotationRate = FRotator::ZeroRotator;
					NewController->Possess(bot);

					bot->OnCharacterKilled.AddDynamic(gm, &AReadyOrNotGameMode::PlayerKilled);
					bot->OnPlayerArrested.AddDynamic(gm, &AReadyOrNotGameMode::PlayerArrested);
					bot->OnCharacterTakeDamage.AddDynamic(gm, &AReadyOrNotGameMode::PlayerTakenDamage);
					bot->OnPlayerFreed.AddDynamic(gm, &AReadyOrNotGameMode::PlayerFreed);
					
				}
			}
		}
	}
}

