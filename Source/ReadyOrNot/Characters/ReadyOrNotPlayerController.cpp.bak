void AReadyOrNotPlayerController::Server_SwapPlayersTeam_Implementation(APlayerState* ps)
{
	AReadyOrNotPlayerState* ourPS = Cast<AReadyOrNotPlayerState>(PlayerState);
	AReadyOrNotPlayerState* theirPS = Cast<AReadyOrNotPlayerState>(ps);

	if (ourPS && ourPS != theirPS && !ourPS->bSquadLeader)
	{
		return;
	}
	
	if (theirPS)
	{

		if (theirPS->GetTeam() == ETeamType::TT_SERT_BLUE)
		{
			theirPS->Server_SetTeam_Implementation(ETeamType::TT_SERT_RED);
		}
		else if (theirPS->GetTeam() == ETeamType::TT_SERT_RED)
		{
			theirPS->Server_SetTeam_Implementation(ETeamType::TT_SERT_BLUE);
		}
	}
}

void AReadyOrNotPlayerController::TakeDamageExec(const float DamageAmount)
{
	if (GetPawn())
	{
		GetPawn()->TakeDamage(DamageAmount, FDamageEvent{UDamageType::StaticClass()}, this, GetPawn());
	}
}

void AReadyOrNotPlayerController::KillSWATTeam()
{
	TArray<AActor*> OutActors;
	UGameplayStatics::GetAllActorsOfClass(GetWorld(), ASWATCharacter::StaticClass(), OutActors);

	for (AActor* actor : OutActors)
	{
		ASWATCharacter* swat = Cast<ASWATCharacter>(actor);
		if (swat)
		{
			FDamageEvent ConsoleDamageEvent = FDamageEvent();
			ConsoleDamageEvent.DamageTypeClass = UDamageType::StaticClass();
			swat->TakeDamage(999.0f, ConsoleDamageEvent, this, swat);
		}
	}
}

void AReadyOrNotPlayerController::InternalSaveStats()
{
	const FStatUnitData* StatUnitData = GetWorld()->GetGameViewport()->GetStatUnitData();
	FString				 LevelName = UGameplayStatics::GetCurrentLevelName(GetWorld(), true);

	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("RenderThreadTime"), StatUnitData->RenderThreadTime);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("GameThreadTime"), StatUnitData->GameThreadTime);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("GPUFrameTime"), StatUnitData->GPUFrameTime[0]);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("FrameTime"), StatUnitData->FrameTime);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("RHITTime"), StatUnitData->RHITTime);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%f"), *LevelName, TEXT("InputLatencyTime"), StatUnitData->InputLatencyTime);

	const FPlatformMemoryStats Stats = FPlatformMemory::GetStats();

	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("TotalPhysical"), Stats.TotalPhysical);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("TotalVirtual"), Stats.TotalVirtual);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("UsedPhysical"), Stats.UsedPhysical);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("UsedVirtual"), Stats.UsedVirtual);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("PeakUsedPhysical"), Stats.PeakUsedPhysical);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("PeakUsedVirtual"), Stats.PeakUsedVirtual);

	FTextureMemoryStats TexMemStats;
	RHIGetTextureMemoryStats(TexMemStats);

	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("DedicatedVideoMemory"), TexMemStats.DedicatedVideoMemory);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("DedicatedSystemMemory"), TexMemStats.DedicatedSystemMemory);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("SharedSystemMemory"), TexMemStats.SharedSystemMemory);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("TotalGraphicsMemory"), TexMemStats.TotalGraphicsMemory);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("AllocatedMemorySize"), TexMemStats.AllocatedMemorySize);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("LargestContiguousAllocation"), TexMemStats.LargestContiguousAllocation);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("TexturePoolSize"), TexMemStats.TexturePoolSize);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%lld"), *LevelName, TEXT("PendingMemoryAdjustment"), TexMemStats.PendingMemoryAdjustment);

	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%ld"), *LevelName, TEXT("NumDrawCalls"), GNumDrawCallsRHI[0]);
	UE_LOG(LogReadyOrNot, Log, TEXT("TestResult;%s;%s;%ld"), *LevelName, TEXT("NumPrimitives"), GNumPrimitivesDrawnRHI[0]);
}

void AReadyOrNotPlayerController::SavePerformanceStats()
{
	GEngine->Exec(GetWorld(), *FString::Printf(TEXT("stat none")));
	GEngine->Exec(GetWorld(), *FString::Printf(TEXT("stat unit")));

	FTimerHandle StatsTimer;
	GetWorldTimerManager().SetTimer(StatsTimer, this, &AReadyOrNotPlayerController::InternalSaveStats, 2.0f, false);
}

void AReadyOrNotPlayerController::ExecuteLineTracePerfTest()
{
	int count = 0;
	FDateTime StartTime = FDateTime::UtcNow();
	if (AReadyOrNotGameState* GameState = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState()))
	{
		for (AReadyOrNotCharacter* Other : GameState->AllReadyOrNotCharacters)
		{
			if (!Other || Other == GetPawn())
				continue;
			FCollisionQueryParams CollisionParams;
			//CollisionParams.AddIgnoredActor(Other);
			CollisionParams.TraceTag = SCENE_QUERY_STAT(LineOfSight);
			CollisionParams.bTraceComplex = true;

			//if (const AReadyOrNotCharacter* OtherCharacter = Cast<AReadyOrNotCharacter>(Other))
			//{
			//	CollisionParams.AddIgnoredActors(OtherCharacter->GetCollisionIgnoredActors());
			//	CollisionParams.AddIgnoredComponents(OtherCharacter->GetCollisionIgnoredComponents());
			//}

			FVector ViewPoint;
			FRotator ViewRotation;
			GetActorEyesViewPoint(ViewPoint, ViewRotation);

			if (ViewPoint == FVector::ZeroVector)
			{
				continue;
			}

			FVector TargetLocation = Other->GetTargetLocation(GetPawn());
			FVector RightVector = Other->GetActorRightVector();

			if (TargetLocation == FVector::ZeroVector || ViewPoint == FVector::ZeroVector)
				continue;

			for (int i = 0; i < 10000; i++)
			{
				FHitResult HeadHit;
				GetWorld()->LineTraceSingleByChannel(HeadHit, ViewPoint, TargetLocation, ECC_Visibility, CollisionParams);
				count++;
			}
		}
	}
	float TimeElapsedInMs = (FDateTime::UtcNow() - StartTime).GetTotalMilliseconds();
	UE_LOG(LogTemp, Warning, TEXT("Line Traces Result: %d Line Traces in %f ms. Average %f"), count, TimeElapsedInMs, TimeElapsedInMs / count);
}

void AReadyOrNotPlayerController::ExecuteSweepTraceSinglePerfTest()
{
	int		  count = 0;
	FDateTime StartTime = FDateTime::UtcNow();
	if (AReadyOrNotGameState* GameState = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState()))
	{
		for (AReadyOrNotCharacter* Other : GameState->AllReadyOrNotCharacters)
		{
			FCollisionQueryParams CapsuleParams(SCENE_QUERY_STAT(CrouchTrace), false, Other);
			float PawnRadius, PawnHalfHeight;
			Other->GetCapsuleComponent()->GetScaledCapsuleSize(PawnRadius, PawnHalfHeight);
			const float	  ShrinkHalfHeight = PawnHalfHeight - PawnRadius;
			const float	  TraceDist = PawnHalfHeight - ShrinkHalfHeight;
			const FVector Down = FVector(0.f, 0.f, -TraceDist);

			FHitResult		Hit(1.f);
			FCollisionShape ShortCapsuleShape = FCollisionShape::MakeSphere(500);
			for (int i = 0; i < 1000; i++)
			{
				bool bBlockingHit = GetWorld()->SweepSingleByChannel(Hit, Other->GetActorLocation(), Other->GetActorLocation() + Down, FQuat::Identity, ECC_Visibility, ShortCapsuleShape, CapsuleParams);
				count++;
			}
		}
	}
	float TimeElapsedInMs = (FDateTime::UtcNow() - StartTime).GetTotalMilliseconds();
	UE_LOG(LogTemp, Warning, TEXT("Sweep Traces Single Result: %d Line Traces in %f ms. Average %f"), count, TimeElapsedInMs, TimeElapsedInMs/count);
}

void AReadyOrNotPlayerController::ExecuteSweepTraceMultiPerfTest()
{
	int		  count = 0;
	FDateTime StartTime = FDateTime::UtcNow();
	if (AReadyOrNotGameState* GameState = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState()))
	{
		for (AReadyOrNotCharacter* Other : GameState->AllReadyOrNotCharacters)
		{
			FCollisionQueryParams CapsuleParams(SCENE_QUERY_STAT(CrouchTrace), false, Other);
			float				  PawnRadius, PawnHalfHeight;
			Other->GetCapsuleComponent()->GetScaledCapsuleSize(PawnRadius, PawnHalfHeight);
			const float	  ShrinkHalfHeight = PawnHalfHeight - PawnRadius;
			const float	  TraceDist = PawnHalfHeight - ShrinkHalfHeight;
			const FVector Down = FVector(0.f, 0.f, -TraceDist);

			TArray<FHitResult> Hits;
			FCollisionShape	   ShortCapsuleShape = FCollisionShape::MakeSphere(500);
			for (int i = 0; i < 10; i++)
			{
				bool bBlockingHit = GetWorld()->SweepMultiByChannel(Hits, Other->GetActorLocation(), Other->GetActorLocation() + Down, FQuat::Identity, ECC_Visibility, ShortCapsuleShape, CapsuleParams);
				count++;
			}
		}
	}
	float TimeElapsedInMs = (FDateTime::UtcNow() - StartTime).GetTotalMilliseconds();
	UE_LOG(LogTemp, Warning, TEXT("Sweep Traces Multi Result: %d Line Traces in %f ms. Average %f"), count, TimeElapsedInMs, TimeElapsedInMs / count);
}

void AReadyOrNotPlayerController::DestroyAllAI()
{
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* ai = *It;
		if (ai->GetController())
			ai->GetController()->Destroy();
		ai->Destroy();
	}
}

void AReadyOrNotPlayerController::DestroyAllSuspects()
{
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* ai = *It;
		if (ai->GetTeam() == ETeamType::TT_SUSPECT)
		{
			if (ai->GetController() )
				ai->GetController()->Destroy();
			ai->Destroy();
		}
	}
}

void AReadyOrNotPlayerController::DestroySwatTeam()
