void AReadyOrNotPlayerController::PrintGPUBrand()
{
	FString DeviceDescription;
	FString GPU = FPlatformMisc::GetPrimaryGPUBrand();
	//FWindowsPlatformMisc::GetGPUDriverInfo(DeviceDescription);

	FString HasRTXCard = UBpVideoSettingsLib::HasRTXCard() ? "true" : "false";
	FString SupportsRTX = UBpVideoSettingsLib::SupportsRayTracing() ? "true" : "false";
	FString CommandLineOptions = FCommandLine::Get();
	FString LaunchedInDx12 = CommandLineOptions.Contains("-dx12") ? "true" : "false";
	V_LOGM(LogReadyOrNot, "GPU: %s, Has RTX Card? %s Supports Ray Tracing? %s", *GPU, *HasRTXCard, *SupportsRTX);
	V_LOGM(LogReadyOrNot, "GPU List: %s", *UBpVideoSettingsLib::GetGPUList());
	V_LOGM(LogReadyOrNot, "Command Line Options: %s", *CommandLineOptions);
	V_LOGM(LogReadyOrNot, "Launched In DX12? %s", *LaunchedInDx12);
}

bool AReadyOrNotPlayerController::SaveFileToUserCloud(FString FullPath)
{
	IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
	if (OnlineSub)
	{
		IOnlineUserCloudPtr UserCloud = OnlineSub->GetUserCloudInterface();
		if (UserCloud.IsValid())
		{
			TArray<uint8> FileContents;
			if (FFileHelper::LoadFileToArray(FileContents, *FullPath))
			{
				ULocalPlayer* LocalPlayer = GetLocalPlayer();
				TSharedPtr<const FUniqueNetId> UniqueNetId = LocalPlayer->GetPreferredUniqueNetId().GetUniqueNetId();
				FOnWriteUserFileCompleteDelegate WriteUserFileCompleteDelegate;
				WriteUserFileCompleteDelegate.BindUObject(this, &AReadyOrNotPlayerController::OnFileSavedTouserCloud);
				UserCloud->AddOnWriteUserFileCompleteDelegate_Handle(WriteUserFileCompleteDelegate);
				//GEngine->AddOnScreenDebugMessage(-1, 30.0f, FColor::Green, "Saving file (" + FullPath + ") to steam cloud ");
				return UserCloud->WriteUserFile(*UniqueNetId, FullPath, FileContents);
			}
		}
	}
	return false;
}

void AReadyOrNotPlayerController::OnFileSavedTouserCloud(bool bWasSuccessful, const FUniqueNetId& UniqueNetId, const FString& FilePath)
{
	//GEngine->AddOnScreenDebugMessage(-1, 30.0f, bWasSuccessful ? FColor::Green : FColor::Red, "Saved file (" + FilePath + ") to steam cloud " + (bWasSuccessful ? "successfully" : "unsuccessfully"));
}

