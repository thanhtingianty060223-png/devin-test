void AReadyOrNotPlayerController::Server_Equip_Implementation(const FString& ItemName)
{
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;
	
	UClass* ItemClass = ULoadoutManager::GetItemByLookupIdx(GetWorld(), *ItemName);
	if (ItemClass)
	{
		ABaseItem* bi = GetWorld()->SpawnActor<ABaseItem>(ItemClass);
		if (bi)
		{
			pc->GetInventoryComponent()->AddInventoryItem(bi);
			pc->GetInventoryComponent()->PutItemInHands(bi);
		}
	}
	
	// if (FItemLookupTable* Row = UBpGameplayHelperLib::GetItemLookupDataTable()->FindRow<FItemLookupTable>(*ItemName, "AReadyOrNotPlayerController::Equip"))
	// {
	// 	UClass* ItemClass = Row->BlueprintClass.LoadSynchronous();
	// 	ABaseItem* bi = GetWorld()->SpawnActor<ABaseItem>(ItemClass);
	// 	if (bi)
	// 	{
	// 		pc->GetInventoryComponent()->AddInventoryItem(bi);
	// 		pc->GetInventoryComponent()->PutItemInHands(bi);
	// 	}
	// }
}

