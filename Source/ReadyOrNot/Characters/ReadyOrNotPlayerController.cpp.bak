void AReadyOrNotPlayerController::StartSpeaking()
{
	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps)
	{
		ps->SetIsTalking(true);
		APlayerCharacter* PlayerCharacter = Cast<APlayerCharacter>(GetPawn());
		if (!PlayerCharacter)
		{
			ps->Server_SetVoiceType(EVoiceType::VT_Team);
			ps->Server_SetVoiceType_Implementation(EVoiceType::VT_Team);
		}
		
		switch(ps->GetVoiceType())
		{
		case EVoiceType::VT_Local:
			UReadyOrNotStatics::GetReadyOrNotGameInstance()->MultiChanPushToTalk(PTTKey::PTTAreaChannel, true);
			break;
		case EVoiceType::VT_Team:
			UReadyOrNotStatics::GetReadyOrNotGameInstance()->MultiChanPushToTalk(PTTKey::PTTTeamChannel, true);
			break;
		default: ;
		}
	}
	
}

void AReadyOrNotPlayerController::StopSpeaking()
{
	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps)
	{
		ps->SetIsTalking(false);
		UReadyOrNotStatics::GetReadyOrNotGameInstance()->MultiChanPushToTalk(PTTKey::PTTAreaChannel, false);
		UReadyOrNotStatics::GetReadyOrNotGameInstance()->MultiChanPushToTalk(PTTKey::PTTTeamChannel, false);
	}
}

void AReadyOrNotPlayerController::CycleVoiceChannel()
{
	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (ps)
	{
		if (ps->GetVoiceType() == EVoiceType::VT_Local)
		{
			ps->Server_SetVoiceType(EVoiceType::VT_Team);
			ps->Server_SetVoiceType_Implementation(EVoiceType::VT_Team);
		}
		else if (ps->GetVoiceType() == EVoiceType::VT_Team)
		{
			ps->Server_SetVoiceType(EVoiceType::VT_Local);
			ps->Server_SetVoiceType_Implementation(EVoiceType::VT_Local);
		}
		
		const UEnum* EnumPtrVoice = FindObject<UEnum>(ANY_PACKAGE, TEXT("EVoiceType"), true);
		FString EnumVoiceStr = EnumPtrVoice? EnumPtrVoice->GetDisplayNameTextByIndex((uint8)ps->GetVoiceType()).ToString() : "Invalid";
		//GEngine->AddOnScreenDebugMessage(-1, 10.0f, FColor::White, "Set Voice Channel to: " + EnumVoiceStr);
	}
}

void AReadyOrNotPlayerController::ClientJoinVoice_Implementation(const FString& OnlineSessionId, const int32& TeamNum)
{
	if (!IsPrimaryPlayer())
		return;

	FString SelectedAudioDevice;
	UBpGameplayHelperLib::LoadSelectedAudioDevice(SelectedAudioDevice);
	UReadyOrNotGameInstance* Gi = UReadyOrNotStatics::GetReadyOrNotGameInstance();
	Gi->SetInputAudioDevice(SelectedAudioDevice);
	PendingVoiceSessionId = OnlineSessionId;
	PendingVoiceTeamNum = TeamNum;
	
	if (!Gi->IsLoggedIn())
	{
		bPendingJoinVoice = true;
	} else
	{
		Gi->JoinVoiceChannels(OnlineSessionId, TeamNum);
	}
}

void AReadyOrNotPlayerController::SendChatMessage(FRChatMessage ChatMessage)
{
	if (ChatMessage.SenderName.IsEmpty())
	{
		if (PlayerState)
		{
			ChatMessage.SenderName = PlayerState->GetPlayerName();
		}
	}
	
	FString newName;
	if (ChatMessage.Message.Split("/profilestart ", nullptr, &newName))
	{
		ConsoleCommand("stat startfile");
		return;
	} else if (ChatMessage.Message.Split("/profilestop ", nullptr, &newName))
	{
		ConsoleCommand("stat stopfile");
		return;
	} 

	if (!ChatMessage.Message.IsEmpty() && !ChatMessage.SenderName.IsEmpty())
		Server_SendChatMessage(ChatMessage);
}

