void AReadyOrNotPlayerController::OnSessionJoinFailed()
{
	for (ULevelStreaming* l : StreamingLevels)
	{
		if (l)
		{
			l->SetShouldBeLoaded(false);
			GetWorld()->RemoveStreamingLevel(l);
		}
	}
	StreamingLevels.Empty();
	
	RemoveLoadingScreen();

	AMainMenuGM* MainMenuGM = Cast<AMainMenuGM>(GetWorld()->GetAuthGameMode());
	if (MainMenuGM)
	{
		MainMenuGM->CreateMainMenu(); 
		const FString MessageText = NSLOCTEXT("MainMenu", "MainMenuFailedSessionJoin", "Failed to Join Session").ToString();
		const FString ButtonText = NSLOCTEXT("MainMenu", "MainMenuOKBtn", "OK").ToString();
		MainMenuGM->ShowMessageDisplayBox(MessageText, ButtonText);
	}
}

