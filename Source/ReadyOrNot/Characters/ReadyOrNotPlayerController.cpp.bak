void AReadyOrNotPlayerController::DisableAllItemMaterials()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	for (TActorIterator<ABaseItem> It(GetWorld()); It; ++It)
	{
		ABaseItem* i = *It;

		TArray<USkeletalMeshComponent*> SkelMeshComps;
		i->GetComponents(SkelMeshComps);
		for (USkeletalMeshComponent* skel: SkelMeshComps)
		{
			for (int32 y = 0; y < skel->GetMaterials().Num(); y++)
			{
				skel->SetMaterial(y, TestMaterial);
			}
		}
	}

	for (TActorIterator<APlayerCharacter> It(GetWorld()); It; ++It)
	{
		APlayerCharacter* i = *It;

		TArray<USkeletalMeshComponent*> SkelMeshComps;
		i->GetComponents(SkelMeshComps);
		for (USkeletalMeshComponent* skel : SkelMeshComps)
		{
			for (int32 y = 0; y < skel->GetMaterials().Num(); y++)
			{
				skel->SetMaterial(y, TestMaterial);
			}
		}
	}
}

void AReadyOrNotPlayerController::DisableAllMaterials()
{
	for (TObjectIterator<USkeletalMeshComponent>It;It;++It)
	{
		for (int32 y = 0; y < It->GetMaterials().Num(); y++)
		{
			It->SetMaterial(y, TestMaterial);
		}
	}

	for (TObjectIterator<UStaticMeshComponent>It; It; ++It)
	{
		for (int32 y = 0; y < It->GetMaterials().Num(); y++)
		{
			It->SetMaterial(y, TestMaterial);
		}
	}
}

