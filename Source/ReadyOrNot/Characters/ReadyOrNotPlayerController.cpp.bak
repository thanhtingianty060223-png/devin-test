void AReadyOrNotPlayerController::PlayAnimationFromLookupTable(FString AnimationRowName)
{
	for (TActorIterator<ACyberneticCharacter> It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* ai = *It;
		ai->PlayMontageFromTable(AnimationRowName);
	}
}

void AReadyOrNotPlayerController::Kill(float time)
{
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;

	if (time <= 0.0f)
	{
		time = 0.01f;
	}
	
	FTimerHandle Handle;
	GetWorld()->GetTimerManager().SetTimer(Handle, pc, &APlayerCharacter::Kill, time);
}

void AReadyOrNotPlayerController::TeleportUp()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (!pc)
		return;
	FVector NewPos = pc->GetActorLocation()+FVector(0,0,400);
	pc->SetActorLocation(NewPos);
}

void AReadyOrNotPlayerController::SetClubMusicMasterVolume(float Volume)
{
	for (TActorIterator<AFMODAmbientSound> It(GetWorld()); It; ++It)
	{
		UFMODAudioComponent* AudioComponent = (*It)->AudioComponent;

		if (AudioComponent->ParameterCache.Find("ClubMusicMasterVolume"))
		{
			AudioComponent->SetParameter("ClubMusicMasterVolume", Volume);
		
			float UserValue = 0.0f, FinalValue = 0.0f;
			AudioComponent->GetParameterValue("ClubMusicMasterVolume", UserValue, FinalValue);
		
			ULog::Info((*It)->GetName() + " | ClubMusicMasterVolume set to " + FString::SanitizeFloat(FinalValue));
		}
	}
}

