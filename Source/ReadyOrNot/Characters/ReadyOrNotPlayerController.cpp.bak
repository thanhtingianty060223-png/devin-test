void AReadyOrNotPlayerController::Server_AdminKickPlayer_Implementation(APlayerState* KickingPlayerState, const FText& ReasonOveride)
{
	if (KickingPlayerState != PlayerState)
	{
		AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
		if (gm)
		{
			for (TActorIterator<APlayerController> It(GetWorld()); It; ++It)
			{
				APlayerController* player = *It;
				if (player->PlayerState == KickingPlayerState)
				{
					FText Reason = NSLOCTEXT("ReadyOrNot", "ReadyOrNot", "You have been kicked by an admin.");
					if (!ReasonOveride.IsEmpty()) Reason = ReasonOveride;
					if (gm->GetReadyOrNotGameSession())
					{
						player->ClientWasKicked(Reason);
						gm->GetReadyOrNotGameSession()->KickPlayer(player, Reason);
					}
					return;
				}
			}
		}
	}
}

bool AReadyOrNotPlayerController::Server_AdminKickPlayer_Validate(APlayerState* KickingPlayerState, const FText& ReasonOveride)
{
	return IsAdmin();
}

void AReadyOrNotPlayerController::Server_AdminBanPlayer_Implementation(APlayerState* BanningPlayerState)
{
	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		for (TActorIterator<APlayerController> It(GetWorld()); It; ++It)
		{
			APlayerController* player = *It;
			if (player->PlayerState == BanningPlayerState)
			{
				if (gm->GetReadyOrNotGameSession())
				{
					FText Reason = NSLOCTEXT("ReadyOrNot", "ReadyOrNot", "You have been kicked by an admin.");
					player->ClientWasKicked(Reason);
					gm->GetReadyOrNotGameSession()->BanPlayer(player, Reason);
					return;
				}
			}
		}
	}
}

bool AReadyOrNotPlayerController::Server_AdminBanPlayer_Validate(APlayerState* BanningPlayerState)
{
	return IsAdmin();
}

void AReadyOrNotPlayerController::Server_AdminAddMapToRotation_Implementation(const FString& MapURL)
{
	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		AReadyOrNotGameSession* gs = gm->GetReadyOrNotGameSession();
		if (gs)
		{
			gs->MapList.AddUnique(MapURL);
			ReplicateMapListIfAdmin();
		}
	}
}

bool AReadyOrNotPlayerController::Server_AdminAddMapToRotation_Validate(const FString& MapURL)
{
	return IsAdmin();
}

void AReadyOrNotPlayerController::Server_AdminAddMapToRotationAtIndex_Implementation(const FString& MapURL, int32 Idx)
{
	AReadyOrNotGameMode* gm = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (gm)
	{
		AReadyOrNotGameSession* gs = gm->GetReadyOrNotGameSession();
		if (gs)
		{
			//int32 removedatIdx;
			for (int32 i = 0; i < gs->MapList.Num(); i++)
			{
				if (gs->MapList[i].Equals(MapURL))
				{
					gs->MapList.RemoveAt(i);
					//removedatIdx = i;
					break;
				}
			}

			if (Idx > gs->MapList.Num() - 1)
			{
				gs->MapList.AddUnique(MapURL);
			}
			else
			{
				gs->MapList.Insert(MapURL, Idx);
			}
			ReplicateMapListIfAdmin();
		}
	}
}

bool AReadyOrNotPlayerController::Server_AdminAddMapToRotationAtIndex_Validate(const FString& MapURL, int32 Idx)
{
	return IsAdmin();
}

