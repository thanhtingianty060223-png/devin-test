	}

	for (TObjectIterator<USkeletalMeshComponent>It;It;++It)
	{
		if (It->GetOwner())
		{
			It->GetOwner()->Destroy();
		}
	}

	for (TObjectIterator<UParticleSystemComponent>It; It; ++It)
	{
		if (It->GetOwner())
		{
			It->GetOwner()->Destroy();
		}
	}

	for (TObjectIterator<UActorComponent>It; It; ++It)
	{
		if (It->GetOwner())
		{
			It->GetOwner()->Destroy();
		}
	}

	// for (TActorIterator<AActor>It(GetWorld()); It; ++It)
	// {
	// 	It->Destroy();
	// }
}

