		if (CallbackData->m_eAuthSessionResponse > EAuthSessionResponse::k_EAuthSessionResponseOK)
		{
			ClientReturnToMainMenuWithTextReason(NSLOCTEXT("ReadyOrNot", "UnableToAuthenticateWithSteam", "Unable to Authenticate with steam"));
		}
	}
	
}*/

bool AReadyOrNotPlayerController::CanSetDepotTo(int32 NewDepot, bool bSameDepot)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (!gs)
	{
		return false;
	}

	AReadyOrNotPlayerState* ps = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (!ps->bSquadLeader)
	{
		return false;
	}

	if (gs->DepotNumber == NewDepot)
	{
		return bSameDepot;
	}

	FLevelDataLookupTable LevelData = UBpGameplayHelperLib::GetLevelData(GetWorld());
	if (!LevelData.DeployableDepots.IsValidIndex(NewDepot))
	{
		return false;
	}

	int32 SquadPointsAvailable = gs->SquadPointsRemaining + gs->DepotCost;
	return LevelData.DeployableDepots[NewDepot].DepotCost <= SquadPointsAvailable;
}

void AReadyOrNotPlayerController::Server_SetDeployableDepot_Implementation(int32 NewDepot)
{
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if (!gs)
	{
		return;
	}

	gs->Server_SetDeployableDepot_Implementation(this, NewDepot);
}

