	return 0.0f;
}

void AReadyOrNotPlayerController::ChangeInputMode(bool bGameMode, bool bMouseCursorEnabled, UWidget* Widget)
{
	if (bGameMode && !bMouseCursorEnabled)
	{
		SetShouldShowMouseCursor(false);
		SetInputMode(FInputModeGameOnly());
	}
	else if (bGameMode && bMouseCursorEnabled)
	{
		FInputModeGameAndUI InputMode;
		InputMode.SetLockMouseToViewportBehavior(EMouseLockMode::LockInFullscreen);
		
		if (Widget)
			InputMode.SetWidgetToFocus(Widget->TakeWidget());
		
		SetShouldShowMouseCursor(true);
		SetInputMode(InputMode);
	}
	else
	{
		// Code repetition somewhat unavoidable here
		FInputModeUIOnly InputMode;
		InputMode.SetLockMouseToViewportBehavior(EMouseLockMode::LockInFullscreen);
		
		if (Widget && Widget->TakeWidget()->SupportsKeyboardFocus())
			InputMode.SetWidgetToFocus(Widget->TakeWidget());

		SetInputMode(InputMode);
		SetShouldShowMouseCursor(bMouseCursorEnabled);
	}
}

void AReadyOrNotPlayerController::EnablePlayerInput()
{
	EnableInput(this);
}

bool AReadyOrNotPlayerController::CanOpenPauseMenu()
{
	if (GetWorld()->GetMapName().Contains("MainMenu"))
	{
		return false;
	}

	if (const APawn* MyPawn = GetPawn())
	{
		if (MyPawn->bBlockInput)
		{
			const AReadyOrNotCharacter* character = Cast<AReadyOrNotCharacter>(MyPawn);

			if (IsValid(character) && !character->IsDeadNotUnconscious())
			{
				return false;
			}
		}
	}

	if (const AGameStateBase* GameStateBase = GetWorld()->GetGameState())
	{
		if (!GameStateBase->HasMatchStarted())
		{
			return false;
		}
	}

	if (HasLoadingScreenInViewport())
	{
		return false;
	}

	if (UBpGameplayHelperLib::IsWidgetOfClassInViewport(GetWorld(), UPauseMenu_Wrapper::StaticClass()))
	{
		return false;
	}

	if (UBpGameplayHelperLib::IsWidgetOfClassInViewport(GetWorld(), UPreMissionPlanning::StaticClass()))
	{
		return false;
	}

	if (UBpGameplayHelperLib::IsWidgetOfClassInViewport(GetWorld(), UMissionEnd::StaticClass()))
	{
		return false;
	}

	if (UBpGameplayHelperLib::IsWidgetOfClassInViewport(GetWorld(), UCollectableWidget::StaticClass()))
	{
		return false;
	}

	return true;
}

void AReadyOrNotPlayerController::OpenPauseMenu()
{
	if (!CanOpenPauseMenu())
	{
		return;
	}

	const FWidgetLookupData WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData("Escape", false);
	if (WidgetData.WidgetClass)
	{
		PauseMenu = CreateWidget<UPauseMenu_Wrapper>(GetWorld(), WidgetData.WidgetClass);
		PauseMenu->AddToViewport(99990);
		PauseMenu->OpenPauseMenu();
	}
}

// Not needed when using an activatable widget with a back-handler.
void AReadyOrNotPlayerController::EscapeMenu()
{
	const AReadyOrNotGameState* GameState = UReadyOrNotStatics::GetReadyOrNotGameState();
	if(GameState && GameState->Loadout_V2 != nullptr)	
		return;
	
	if (WidgetStack.Num() > 0)
	{
		// hack to always save keybinds when exiting
		UBpGameplayHelperLib::SaveKeybinds();
		const FString RemoveWidget = WidgetStack.Pop();
		
		UBpGameplayHelperLib::RemoveWidgetFromViewport(RemoveWidget);
		
		if (WidgetStack.Num() > 0)
		{
			// Note: every time we pop and have a widget in the stack, just focus on it. No need to recreate it
			if (UUserWidget* LastWidget = UBpGameplayHelperLib::GetFirstWidgetFromViewport(WidgetStack.Last()))
			{
				const FWidgetLookupData WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData(WidgetStack.Last());
				
				ChangeInputMode(false, WidgetData.bMouseUIOnly || WidgetData.bShowMouseCursor, LastWidget);
			}
		}
		else
		{
			if ((bPreEscapeMenuMouseEnabled || (GetWorld()->GetMapName().Contains("MainMenu")) && !UBpGameplayHelperLib::HasWidgetInViewport("CharacterHUD_V2")))
			{
				UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
				gi->bForceShowMouseCursor = true;
				ChangeInputMode(true, true);
			}
			else
			{
				UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
				gi->bForceShowMouseCursor = false;
				ChangeInputMode(true, false);
			}
			
			if (GetPawn())
			{
				GetPawn()->bBlockInput = false;
			}
		}
	}
}

void AReadyOrNotPlayerController::ShowTabMenu()
{
	ASpectatePawn* SpectatePawn = Cast<ASpectatePawn>(GetPawn());
	if (!SpectatePawn)
		return;
	
	if (TabMenuWidget)
		HideTabMenu();
	
	TabMenuWidget = CreateWidget<UUserWidget>(this, TabMenuWidgetClass);
	if (TabMenuWidget)
		TabMenuWidget->AddToViewport();
}

void AReadyOrNotPlayerController::HideTabMenu() {
        if (!TabMenuWidget)
                return;

        TabMenuWidget->RemoveFromParent();
        TabMenuWidget = nullptr;
}
bool AReadyOrNotPlayerController::IsOverlayHudVisible() const {
	return CVarRonShowHudOverlay.GetValueOnAnyThread() == 1;
}

void AReadyOrNotPlayerController::SetupSubtitles()
{
	DestroySubtitles();

	if (!IsLocalPlayerController())
		return;
	
	const FWidgetLookupData WidgetData = UBpGameplayHelperLib::GetWidgetDataFromLookupData("SubtitlesOverlay");
	if (!WidgetData.WidgetClass)
		return;
	
	SubtitlesWidget = CreateWidget<UUserWidget>(this, WidgetData.WidgetClass);
	if (SubtitlesWidget)
	{
		SubtitlesWidget->AddToViewport(WidgetData.ZOrder);
	}
}

void AReadyOrNotPlayerController::DestroySubtitles()
{
	if (IsValid(SubtitlesWidget))
		SubtitlesWidget->RemoveFromParent();

	SubtitlesWidget = nullptr;
}

void AReadyOrNotPlayerController::ToggleDeployMenu()
{
	if (!GET_GAME_STATE(ALobbyGS))
		return;

	
	DisableInput(this);
	
	if (UReadyOrNotStatics::GetReadyOrNotGameState()->MatchState == EMatchState::MS_Playing)
	{
		if (UBpGameplayHelperLib::IsWidgetOfClassInViewport(GetWorld(), UPreMissionPlanning::StaticClass()))
		{			
			if(GetReadyOrNotPlayerState()->bIsInGame)
			{
				EscapeMenu();							
			}
		}
		else
		{
			for (TObjectIterator<UHumanCharacterHUD_V2>It; It; ++It)
			{
				UHumanCharacterHUD_V2* HumanCharacterHUD_V2 = *It;
				HumanCharacterHUD_V2->SetVisibility(ESlateVisibility::Collapsed);
			}
			Client_CreateWidget_Implementation(AReadyOrNotPlayerController::MENU_PRE_MISSION_PLANNING, true);
			PlayerCameraManager->StartCameraFade(4.0f, 0.0f, 3.0f, FLinearColor::Black);
			// call this twice, once to start the level load
			UReadyOrNotFunctionLibrary::StartTimerForCallback(UReadyOrNotStatics::GetReadyOrNotGameState(), &AReadyOrNotGameState::LoadSubPreMissionPlanningFromTimer, 0.1f);
			UReadyOrNotFunctionLibrary::StartTimerForCallback(UReadyOrNotStatics::GetReadyOrNotGameState(), &AReadyOrNotGameState::LoadSubPreMissionPlanningFromTimer, 1.0f);
		}
	}

	UReadyOrNotFunctionLibrary::StartTimerForCallback(this, &AReadyOrNotPlayerController::EnablePlayerInput, 0.75f);
}

void AReadyOrNotPlayerController::DownloadBlacklistHashes()
{
	UBpGameplayHelperLib::GetRONGameInstance()->ReadyOrNotBackend->DownloadHashes();
}

void AReadyOrNotPlayerController::DestroyAllExceptClosestCharacter()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	ACyberneticCharacter* ClosestAI = nullptr;
	float ClosestDist = BIG_DIST;
	for (TActorIterator<ACyberneticCharacter>It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* AI = *It;
		float Dist =(AI->GetActorLocation() - GetPawn()->GetActorLocation()).Size();
		if (Dist < ClosestDist)
		{
			ClosestAI = AI;
			ClosestDist = Dist;
		}
	}

	for (TActorIterator<ACyberneticCharacter>It(GetWorld()); It; ++It)
	{
		ACyberneticCharacter* AI = *It;
		if (AI->IsOnSWATTeam())
			continue;

		if (AI != ClosestAI)
		{
			AI->Destroy();
		}
	}
}

void AReadyOrNotPlayerController::DestroyAllExceptClosestDoor()
{
#if UE_BUILD_SHIPPING
	return;
#endif
	ADoor* ClosestDoor  = nullptr;
	float ClosestDist = BIG_DIST;
	for (TActorIterator<ADoor>It(GetWorld()); It; ++It)
	{
		ADoor* Door = *It;
		float Dist =(Door->GetActorLocation() - GetPawn()->GetActorLocation()).Size();
		if (Dist < ClosestDist)
		{
			ClosestDoor = Door;
			ClosestDist = Dist;
		}
	}

	for (TActorIterator<ADoor>It(GetWorld()); It; ++It)
	{
		ADoor* Door = *It;

		if (Door != ClosestDoor)
		{
			Door->Destroy();
		}
	}
}

void AReadyOrNotPlayerController::OnlyCastLocalPlayerDynamicShadow()
{
	if (!UBpGameplayHelperLib::GetLocalPlayerCharacter(GetWorld()))
		return;
	
	for (TObjectIterator<USkeletalMeshComponent>It;It;++It)
	{
		AReadyOrNotCharacter* OwnerChar = Cast<AReadyOrNotCharacter>(It->GetOwner());
		if (!OwnerChar)
		{
			It->SetCastShadow(false);
		}
	}

	for (TObjectIterator<UStaticMeshComponent>It; It; ++It)
	{
		if (!Cast<ADoor>(It->GetOwner()))
			It->SetCastShadow(false);
	}
}

