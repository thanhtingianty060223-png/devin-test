void AReadyOrNotPlayerController::ClientStartOnlineGame_Implementation()
{
	if (!IsPrimaryPlayer())
		return;

	AReadyOrNotPlayerState* RonPlayerState = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (RonPlayerState)
	{
		IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
		if (OnlineSub)
		{
			IOnlineSessionPtr Sessions = OnlineSub->GetSessionInterface();
			if (Sessions.IsValid() && (Sessions->GetNamedSession(GameSessionName) != nullptr))
			{
				UE_LOG(LogOnline, Log, TEXT("Starting session on client"));
				Sessions->StartSession(GameSessionName);
			}
		}
	}
	else
	{
		// Keep retrying until player state is replicated
		GetWorld()->GetTimerManager().SetTimer(TimerHandle_ClientStartOnlineGame, this, &AReadyOrNotPlayerController::ClientStartOnlineGame_Implementation, 0.2f, false);
	}
}

void AReadyOrNotPlayerController::ClientEndOnlineGame_Implementation()
{
	if (!IsPrimaryPlayer())
		return;

	AReadyOrNotPlayerState* RonPlayerState = Cast<AReadyOrNotPlayerState>(PlayerState);
	if (RonPlayerState)
	{
		IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
		if (OnlineSub)
		{
			IOnlineSessionPtr Sessions = OnlineSub->GetSessionInterface();
			if (Sessions.IsValid() && (Sessions->GetNamedSession(GameSessionName) != nullptr))
			{
				UE_LOG(LogOnline, Log, TEXT("Ending session on client"));
				Sessions->EndSession(GameSessionName);
			}
		}
	}
}

