bool AReadyOrNotPlayerController::IsAdmin()
{
	AReadyOrNotGameState* gs = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (gs)
	{
		if (!gs->IsAdminPlayerController(this))
			return false;
	}
	return true;
}

bool AReadyOrNotPlayerController::StreamInLevel(const FString& NewLevel, const FString& Options, ULevelStreaming*& OutStreamedLevel, FLevelStreamOptions LevelStreamOptions)
{
	StreamingLevel = NewLevel;
	StreamingOptions = Options;

	if (NewLevel.Contains("MainMenu"))
	{
		LevelStreamOptions.bStreamInLevelBeforeLoad = true;
		LevelStreamOptions.bExecuteOpenLevelWhenLoaded = true;
	}

	
	auto ObjectLibrary = UObjectLibrary::CreateLibrary(UWorld::StaticClass(), false, true);
	ObjectLibrary->LoadAssetDataFromPath(TEXT("/Game/ReadyOrNot/Level"));
	TArray<FAssetData> AssetDatas;
	ObjectLibrary->GetAssetDataList(AssetDatas);
	for (int32 i = 0; i < AssetDatas.Num(); ++i)
	{
		FAssetData& AssetData = AssetDatas[i];
 
		auto name = AssetData.AssetName.ToString();
		if (AssetData.AssetName == *NewLevel)
		{
			if (GetWorld()->GetMapName() != NewLevel && LevelStreamOptions.bStreamInLevelBeforeLoad)
			{
				OutStreamedLevel = NewObject<ULevelStreaming>(GetWorld(), ULevelStreamingDynamic::StaticClass(), NAME_None, RF_NoFlags);
				StreamingLevels.Add(OutStreamedLevel);
				OutStreamedLevel->SetWorldAsset(TSoftObjectPtr<UWorld>(AssetData.ToSoftObjectPath()));
				GetWorld()->AddStreamingLevel(OutStreamedLevel);
				OutStreamedLevel->SetShouldBeLoaded(true);
				OutStreamedLevel->OnLevelLoaded.AddDynamic(this, &AReadyOrNotPlayerController::OnStreamedLevelLoadedComplete);
				if (LevelStreamOptions.bExecuteOpenLevelWhenLoaded)
				{
					OutStreamedLevel->OnLevelLoaded.AddDynamic(this, &AReadyOrNotPlayerController::OnStreamedLevelLoadedExecuteOpen);	
					
				}
				if (LevelStreamOptions.bShouldRemoveLoadingScreen)
				{
					OutStreamedLevel->OnLevelLoaded.AddDynamic(this, &AReadyOrNotPlayerController::OnStreamedLevelLoadedRemovingLoadingScreen);
				}
			} else
			{
				if (LevelStreamOptions.bExecuteOpenLevelWhenLoaded)
				{
					OnStreamedLevelLoadedExecuteOpen();
				}
				if (LevelStreamOptions.bShouldRemoveLoadingScreen)
				{
					OnStreamedLevelLoadedRemovingLoadingScreen();
				}
			}
			
		
			
			if (LevelStreamOptions.bShouldCreateLoadingScreen)
			{
				Client_CreateLoadingScreen_Implementation(NewLevel, LevelStreamOptions.ModeName, LevelStreamOptions.SessionName, LevelStreamOptions.bIsSeamlessTravel);
			}
			
			return true;
		}
	
	}

	return false;
}

void AReadyOrNotPlayerController::OnStreamedLevelLoadedComplete()
{
	for (ULevelStreaming* l : StreamingLevels)
	{
		if (l)
		{
			l->SetShouldBeLoaded(false);
			GetWorld()->RemoveStreamingLevel(l);
		}
	}
	StreamingLevels.Empty();
}

void AReadyOrNotPlayerController::OnLevelOpen()
{
	AReadyOrNotGameMode* GameMode = Cast<AReadyOrNotGameMode>(GetWorld()->GetAuthGameMode());
	if (GameMode)
	{
		GameMode->ProcessServerTravel(StreamingLevel + StreamingOptions, true);
	} else
	{
		UGameplayStatics::OpenLevel(GetWorld(), *StreamingLevel, true, StreamingOptions);
	}

	StreamingLevel = "";
	StreamingOptions = "";
}

void AReadyOrNotPlayerController::OnStreamedLevelLoadedExecuteOpen()
{
	if (StreamingLevel.Contains("MainMenu"))
	{
		ConsoleCommand("Disconnect");
		UGameplayStatics::OpenLevel(GetWorld(), *StreamingLevel, true, StreamingOptions);
	} else
	{
		GetWorld()->GetTimerManager().SetTimer(TH_OpenLevelSwtichDelay, this, &AReadyOrNotPlayerController::OnLevelOpen, 2.0f, false);
	}
}

void AReadyOrNotPlayerController::OnStreamedLevelLoadedRemovingLoadingScreen()
{
	GetWorld()->GetTimerManager().SetTimer(TH_OpenLevelRemoveLoadingScreenDelay, this, &AReadyOrNotPlayerController::RemoveLoadingScreen, 5.0f, false);

}

bool AReadyOrNotPlayerController::StreamInSession(FBlueprintSessionResult SessionResult, ULevelStreaming*& OutStreamedLevel, bool bShouldCreateLoadingScreen)
{
	FString NewLevel;
	SessionResult.OnlineResult.Session.SessionSettings.Get(SETTING_MAPNAME, NewLevel);

#if defined(USE_EOS) || defined(TARGET_CONSOLE)	
	StreamingLevel = NewLevel;
#endif
	
	JoinSession = UJoinSessionCallbackProxyAdvanced::JoinSession(GetWorld(), this, SessionResult);
	JoinSession->OnSuccess.AddDynamic(this, &AReadyOrNotPlayerController::AReadyOrNotPlayerController::OnSessionJoinSuccess);
	JoinSession->OnFailure.AddDynamic(this, &AReadyOrNotPlayerController::AReadyOrNotPlayerController::OnSessionJoinFailed);
	JoinSession->Activate();
	if (bShouldCreateLoadingScreen)
	{
		CreateSessionLoadingScreen(SessionResult);
	}
	
	auto ObjectLibrary = UObjectLibrary::CreateLibrary(UWorld::StaticClass(), false, true);
	ObjectLibrary->LoadAssetDataFromPath(TEXT("/Game/ReadyOrNot/Level"));
	TArray<FAssetData> AssetDatas;
	ObjectLibrary->GetAssetDataList(AssetDatas);
	for (int32 i = 0; i < AssetDatas.Num(); ++i)
	{
		FAssetData& AssetData = AssetDatas[i];
 
		auto name = AssetData.AssetName.ToString();
		if (AssetData.AssetName == *NewLevel)
		{			
			return true;
		}
	
	}

	return false;
}

void AReadyOrNotPlayerController::OnSessionJoinSuccess()
{
	// // don't do anything maybe?? handle it on game state start
	// for (ULevelStreaming* l : StreamingLevels)
	// {
	// 	if (l)
	// 	{
	// 		l->SetShouldBeLoaded(false);
	// 	}
