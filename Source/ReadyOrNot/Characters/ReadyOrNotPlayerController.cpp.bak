const FString AReadyOrNotPlayerController::MENU_PRE_MISSION_PLANNING = "PreMissionPlanning";

void AReadyOrNotPlayerController::UpdateRichPresence(FString MapName)
{
	FOnlineKeyValuePairs<FString, FVariantData> Keys;
	FString MissionName = UBpGameplayHelperLib::GetMapDetailsFromName(MapName).FriendlyLevelName.ToString();
	if (!MissionName.IsEmpty())
	{
		Keys.Add("mission", FVariantData(FString(*MissionName)));
	}

	FString StatusStr = "Playing Ready Or Not";
	if (MapName.Contains("MainMenu"))
	{
		Keys.Add("steam_display", FVariantData(FString(TEXT("#Status_AtMainMenu"))));
		StatusStr = "At the Main Menu";
	} else if (MapName.Contains("RON_STATION_CORE"))
	{
		Keys.Add("steam_display", FVariantData(FString(TEXT("#Status_Custom"))));
		StatusStr = "Los Suenos Police Headquarters";
		Keys.Add("custom", FVariantData(FString(*StatusStr)));
	} else
	{
		Keys.Add("steam_display", FVariantData(FString(TEXT("#Status_InMission"))));
		if (!MissionName.IsEmpty())
		{
			StatusStr = FString::Printf(TEXT("In A Mission [%s]"), *MissionName);
		}
	}
	UReadyOrNotStatics::GetReadyOrNotGameInstance()->SetPresenceForLocalPlayers(StatusStr, Keys);
}

void AReadyOrNotPlayerController::OnUnPossess()
{
	APlayerCharacter* PlayerCharacter = Cast<APlayerCharacter>(GetPawn());
	if (PlayerCharacter && PlayerCharacter->GetPlayerPostProcessing())
	{
		PlayerCharacter->GetPlayerPostProcessing()->StopPostProcessEffect_Name("NVG");
	}
	Super::OnUnPossess();
}

AReadyOrNotPlayerController::AReadyOrNotPlayerController()
{
	PrimaryActorTick.bTickEvenWhenPaused = true;
	bShouldPerformFullTickWhenPaused = true;
	bCanPossessWithoutAuthority = true;

	ProgressionComp = CreateDefaultSubobject<UProgressionComponent>(TEXT("ProgressionComp"));

	PlayerCameraManagerClass = AReadyOrNotPlayerCameraManager::StaticClass();
}

void AReadyOrNotPlayerController::GetLifetimeReplicatedProps(TArray<FLifetimeProperty>& OutLifetimeProps) const
{
	Super::GetLifetimeReplicatedProps(OutLifetimeProps);
	DOREPLIFETIME(AReadyOrNotPlayerController, ReplicatedMapList);
	// ##UE5UPGRADE## Zeus
	// DOREPLIFETIME(AReadyOrNotPlayerController, Rep_MatchmakingServerInfo);
	// DOREPLIFETIME(AReadyOrNotPlayerController, Rep_MatchmakingPartyInit);
	DOREPLIFETIME(AReadyOrNotPlayerController, MyVoteData);
	DOREPLIFETIME(AReadyOrNotPlayerController, ServerSideChecksum);
}

void AReadyOrNotPlayerController::BeginPlay()
{
	Super::BeginPlay();
#ifdef SUPPORTER_ONLY_BUILD
	if (!UGameFeatureLibrary::IsGameVersionEnabled(DLC_SUPPORTER))
	{
		if (!GetWorld()->GetMapName().Contains("MainMenu"))
		{
			ClientReturnToMainMenuWithTextReason(FText());
			return;
		}
	}
#endif

	SetupSubtitles();
	
	ConsoleCommand("net.UseAdaptiveNetUpdateFrequency 0");
	// PSO Cache
	// https://docs.unrealengine.com/5.0/en-US/optimizing-rendering-with-pso-caches-in-unreal-engine/

	// Shady: Disabled for now - likely cause of performance issues
	// ConsoleCommand("r.ShaderPipelineCache.Enabled 1");
	// ConsoleCommand("r.RayTracing.NonBlockingPipelineCreation 1");
	// ConsoleCommand("r.RayTracing.Reflections.ExperimentalDeferred 1");
	// ConsoleCommand("r.AmbientOcclusion.Compute 1");

	UReadyOrNotStatics::GetReadyOrNotGameInstance()->RetryLogin();
	if (IsLocalController())
	{
		
		if (ServerSideChecksum != UReadyOrNotStatics::GetReadyOrNotGameInstance()->Checksum)
		{
			Server_SetChecksum(	UReadyOrNotStatics::GetReadyOrNotGameInstance()->Checksum);
		}
	}


	UVOIPStatics::SetMicThreshold(-1.0f);
	ConsoleCommand("voice.MicNoiseReleaseTime 1100");
	ConsoleCommand("voice.MicNoiseAttackTime 0");
	ConsoleCommand("voice.MicNoiseGateThreshold 0.0");
	ConsoleCommand("voice.JitterBufferDelay 0.5");
#if UE_BUILD_SHIPPING && ENABLE_ANTI_PIRACY_CHECKS && PLATFORM_WINDOWS
	IOnlineSubsystem* OnlineSub = IOnlineSubsystem::Get();
	if (OnlineSub)
	{
		if ( (FCString::Atoi(*OnlineSub->GetAppId()) != 420410 * 2 && FCString::Atoi(*OnlineSub->GetAppId()) != 572100 * 2) || FCString::Atoi(*OnlineSub->GetAppId()) == 120 * 4)
		{
			AActor* MyNullPtr = nullptr;
			MyNullPtr->SetActorLocation(FVector::ZeroVector);
		}
		
	}
#endif

	UpdateRichPresence(GetWorld()->GetMapName());
	ConsoleCommand("a.PlayerCharacter.PelvisFPMovementDamping .38");
	ConsoleCommand("a.PlayerCharacter.PelvisFPMovementBob.Enable 1");
	
	ACoopGS* gs = Cast<ACoopGS>(GetWorld()->GetGameState());
	if(gs&&gs->MatchState==EMatchState::MS_Playing)
	{
		bStartedCoopAsSpectator = true;
		PlayerCameraManager->StartCameraFade(1,1,0.1,FLinearColor(0,0,0),false,true);
       	Server_StartSpectating();
	}
	else
	{
		bStartedCoopAsSpectator = false;
	}
	
	
	
#if !WITH_EDITOR
	ConsoleCommand("DisableAllScreenMessages");
#endif
#ifdef NO_DRAW_DEBUG
	ConsoleCommand("a.DisableAllVisualDebug 1");
#endif
	if (GEngine->GameUserSettings)
	{
		FString ViewDistanceQuality = "sg.ViewDistanceQuality " + FString::FromInt(FMath::Clamp(GEngine->GameUserSettings->ScalabilityQuality.ViewDistanceQuality, 2, 4));
		ConsoleCommand(ViewDistanceQuality);
		// may resolve a hitch by forcing shadow quality off and on?
		ConsoleCommand("sg.ShadowQuality 0");
		FString ShadowQuality = "sg.ShadowQuality " + FString::FromInt(FMath::Clamp(GEngine->GameUserSettings->ScalabilityQuality.ShadowQuality, 0, 4));
		ConsoleCommand(ShadowQuality);
	}
//	ClientRequestSteamAuth();

	RecreateOverlays();

	//GetWorld()->GetTimerManager().SetTimer(TriggerInvalidateWidgets_Handle, this, &AReadyOrNotPlayerController::TriggerInvalidateWidgets, 1.0f, true, 1.0f);

	ConsoleCommand("r.OneFrameThreadLag 1");

#if defined(TARGET_CONSOLE)
	UReadyOrNotConsoleFunctionLibrary::ConsoleApplyLevelSpecificSettings("", false);
#else
	UReadyOrNotGameUserSettings* Settings = Cast<UReadyOrNotGameUserSettings>(UBpVideoSettingsLib::GetGameUserSettings());
	if (Settings)
	{
		Settings->ApplyCommandLineOverrides();
	}
#endif

	ConsoleCommand("r.Shadow.CSM.MaxCascades 1");
	
#if WITH_EDITOR
// Fixes a bug where only the server (or client 1) gets the appropriate resolution settings
	const ULevelEditorPlaySettings* PlayInSettings = GetDefault<ULevelEditorPlaySettings>();
	int32 resX = PlayInSettings->NewWindowWidth;
	int32 resY = PlayInSettings->NewWindowHeight;
	FString resCommand = "r.setres " + FString::SanitizeFloat(resX) + "x" + FString::SanitizeFloat(resY);
	ConsoleCommand(resCommand);
#endif

	//Force depth of field off! it doesn't work with fov shader
	//Fixes Bug #98553 Clients gun vision becomes blurry when aiming down sight
	ConsoleCommand("r.DepthOfFieldQuality 0");

	//Fix for Bug #98470 where brightness changes significantly based on post process quality settings
	ConsoleCommand("r.EyeAdaptationQuality 4", false);

	ConsoleCommand("r.RenderTargetPoolMin 2000");

#if defined RTX_DMO
	UReadyOrNotGameUserSettings* us = Cast<UReadyOrNotGameUserSettings>(GEngine->GetGameUserSettings());
	if (us)
	{
		bRTXDMOOn = us->bRayTracingEnabled;
		OnRTXDMOChanged.Broadcast(bRTXDMOOn);
	}
#endif

#if defined(TARGET_CONSOLE)
	UpdateMouseCursorVisibility();
#endif

//#if defined(WITH_ACHIEVEMENTS_V1)	
//	UAchievementSubsystem* AchievementsSubsystem = UReadyOrNotStatics::GetReadyOrNotGameInstance()->GetSubsystem<UAchievementSubsystem>();
//	if (AchievementsSubsystem)
//		AchievementsSubsystem->LateInitialize(); // need to have user ready before doing the initialization
//#endif


	LoadAimAssistIntensity();
	SetActiveAimAssistConfig(GetAimAssistConfigByIntensity(AimAssistIntensity, false));
	
}

void AReadyOrNotPlayerController::EndPlay(const EEndPlayReason::Type EndPlayReason)
{
	Super::EndPlay(EndPlayReason);
//	CancelSteamAuthForPlayerController();
}


void AReadyOrNotPlayerController::Server_SetHasFinishedLoading_Implementation()
{
	GetReadyOrNotPlayerState()->bHasFinishedLoading = true;
}

bool AReadyOrNotPlayerController::Server_SetHasFinishedLoading_Validate()
{
	return true;
}

FKey AReadyOrNotPlayerController::GetInputKey(FName InputName)
{
	UInputSettings* Settings = const_cast<UInputSettings*>(GetDefault<UInputSettings>());
	const TArray<FInputActionKeyMapping>& Axes = Settings->GetActionMappings();

	for (const FInputActionKeyMapping& Mapping : Axes)
	{
		if (Mapping.ActionName == InputName)
		{
			return Mapping.Key;
		}
	}
	return FKey();
}

void AReadyOrNotPlayerController::Tick(float DeltaSeconds)
{
	Super::Tick(DeltaSeconds);
	
	SetPiratedTrue();

	APlayerCharacter* PlayerCharacter = Cast<APlayerCharacter>(GetPawn());
	if (PlayerCharacter)
	{
		
#if defined(TARGET_PS5)
		// dualsense gyro aiming prototype
		if (!bWasAimingLastFrame && PlayerCharacter->bAiming)
		{
			bWasAimingLastFrame = true;

			FSonyApplication* SonyApp = FSonyApplication::GetSonyApplication();
			FSonyInputInterface* Interface = reinterpret_cast<FSonyInputInterface*>(SonyApp->GetInputInterface());
			Interface->ResetControllerOrientation(0);
		}

		FVector Tilt;
		FVector RotationRate;
		FVector Acceleration;
		FVector Gravity;

		GetInputMotionState(Tilt, RotationRate, Acceleration, Gravity);
		Tilt.Z = -Tilt.Z;
		Tilt.Y = -Tilt.Y;
#endif

		// Clamp the control rotation only in PlayerCharacter
		FRotator ClampedControlRotation = GetControlRotation();
		ClampedControlRotation.Normalize();
		ClampedControlRotation.Pitch = FMath::Clamp(ClampedControlRotation.Pitch, -72.0f, 80.0f);

#if defined(TARGET_PS5)
		if (PlayerCharacter->bAiming)
		{
			FVector Offset;
			Offset.Z = FMath::Clamp(Tilt.Z, -30.0f, 30.0f) / 3.0f;
			Offset.X = FMath::Clamp(Tilt.X, -30.0f, 30.0f) / 3.0f;
			
			UE_LOG(LogReadyOrNot, Log, TEXT("Adjusting pitch: %f"), Offset.Z);
			UE_LOG(LogReadyOrNot, Log, TEXT("Adjusting yaw: %f"), Offset.X);

			ClampedControlRotation.Add(-PreviousTiltOffset.Z, -PreviousTiltOffset.X, 0.0);
			ClampedControlRotation.Add(Offset.Z, Offset.X, 0.0);
			PreviousTiltOffset = Offset;
		}
		else
		{
			PreviousTiltOffset = FVector(0,0,0);
			bWasAimingLastFrame = false;
		}
#endif

		SetControlRotation(ClampedControlRotation);
		
		if (PlayerCharacter->IsMoving())
		{
			SecondsSinceLastMovement = 0.0f;
		}
		else
		{
			SecondsSinceLastMovement += GetWorld()->GetDeltaSeconds();
		}
	}

	if (WidgetStack.Num() > 0)
	{
		if (FShaderPipelineCache::IsBatchingPaused())
		{
			FShaderPipelineCache::ResumeBatching();
		}
			
	}
	else
	{
		if (!FShaderPipelineCache::IsBatchingPaused())
		{
			FShaderPipelineCache::PauseBatching();
		}
	}

	if (bStatsProfiledQueued)
	{
		if (WidgetStack.Num() == 0)
		{
			UReadyOrNotStatics::GetReadyOrNotGameInstance()->ReadyOrNotBackend->StartCapturingProfile();
			bStatsProfiledQueued = false;
		}
	}

	if (HasAuthority())
	{
		bool bDoChecksum;
		UBpGameplayHelperLib::LoadServersideChecksum(bDoChecksum);
#if UE_SERVER
		bDoChecksum = false;
#endif
		if (bDoChecksum)
		{
			if (ServerSideChecksum != 0)
			{
				if (ServerSideChecksum != UReadyOrNotStatics::GetReadyOrNotGameInstance()->Checksum)
				{
					if (!bStartedChecksumKick)
					{
						bStartedChecksumKick = true;
						ClientWasKicked(FText::FromString(XorString("You have been kicked: Pak Checksum mismatch (server requires you to be running the same mods)")));
					}
				}
			}
		}
	}

	UReadyOrNotGameInstance* Gi = UReadyOrNotStatics::GetReadyOrNotGameInstance();
	float MicInputGain;
	UBpGameplayHelperLib::GetMicInputGain(MicInputGain);
	if (LastSetMicInputGain != MicInputGain)
	{
		LastSetMicInputGain = MicInputGain;
		Gi->SetInputVolume(MicInputGain);
	}

	float NA, VOIPVolume;
	UBpGameplayHelperLib::GetVolumes(NA, NA, NA, NA, VOIPVolume);
	if (LastSetVOIPVolume != VOIPVolume)
	{
		LastSetVOIPVolume = VOIPVolume;
		Gi->SetOutputVolume(VOIPVolume);
	}

	if (IsLocalController())
	{
		UReadyOrNotStatics::GetReadyOrNotGameInstance()->Update3DPosition(GetPawnOrSpectator());
		if (UReadyOrNotStatics::GetReadyOrNotGameInstance()->bPendingRemoveLoadingScreenAfterHostLoaded)
		{
			RemoveLoadingScreen();
		}

		if (GetReadyOrNotPlayerState())
		{
			if (UReadyOrNotStatics::GetReadyOrNotGameInstance()->bClientHasFinishedLoading
				&& !GetReadyOrNotPlayerState()->bHasFinishedLoading)
			{
				Server_SetHasFinishedLoading();
			}
		}

	}

	/*
	if (GetReadyOrNotPlayerState())
	{
		if (HasAuthority() && IsLocalController())
		{
			GetReadyOrNotPlayerState()->bSquadLeader = true;
		} else
		{
			GetReadyOrNotPlayerState()->bSquadLeader = false;
		}
	}
	*/

	#if !UE_BUILD_SHIPPING
	if (CVarRonFollowActiveShooter.GetValueOnAnyThread() == 1 || CVarRonFollowActiveShooterGunCam.GetValueOnAnyThread() == 1)
	{
		if (!SpectateCamera)
		{
			SpectateCamera = GetWorld()->SpawnActor<ACameraActor>();
		}
		else
		{
			for (TActorIterator<ADoor>It(GetWorld()); It; ++It)
			{
				It->PrimaryActorTick.TickInterval = 0.0f;
			}
			
			for (TObjectIterator<USuspectCombatActivity> It; It; ++It)
			{
				if (It && It->GetCharacter() && It->GetOwningController()->IsPerformingCustomAction("ActiveShooter"))
				{
					SetViewTarget(SpectateCamera);

					if (CVarRonFollowActiveShooterGunCam.GetValueOnAnyThread() == 0 || !It->GetCharacter()->GetEquippedItem())
					{
						FHitResult Hit; 
						FCollisionObjectQueryParams CollisionObjectQueryParams;
						CollisionObjectQueryParams.AddObjectTypesToQuery(ECC_WorldStatic); 
						CollisionObjectQueryParams.AddObjectTypesToQuery(ECC_WorldDynamic);
						CollisionObjectQueryParams.AddObjectTypesToQuery(ECC_DOOR);
						GetWorld()->LineTraceSingleByObjectType(Hit, It->GetCharacter()->GetActorLocation(), It->GetCharacter()->GetActorLocation() + It->GetCharacter()->GetActorForwardVector() * -160.0f + FVector(0.0f, 0.0f, 85.0f) + It->GetCharacter()->GetActorRightVector() * 30.0f, CollisionObjectQueryParams);
						if (Hit.bBlockingHit)
						{
							SpectateCamera->SetActorLocation( FMath::VInterpTo(SpectateCamera->GetActorLocation(), Hit.ImpactPoint + Hit.ImpactNormal * 20.0f, DeltaSeconds, 10.0f));
						} else
						{
							
							SpectateCamera->SetActorLocation(FMath::VInterpTo(SpectateCamera->GetActorLocation(), Hit.TraceEnd, DeltaSeconds, 3.0f));
						}

						if (It->GetOwningController()->GetTrackedTarget() && It->GetOwningController()->LineOfSightTo(It->GetOwningController()->GetTrackedTarget()))
						{
							SpectateCamera->SetActorRotation(FMath::RInterpTo(SpectateCamera->GetActorRotation(), UKismetMathLibrary::FindLookAtRotation(SpectateCamera->GetActorLocation(), It->GetOwningController()->GetTrackedTarget()->GetActorLocation()), DeltaSeconds, 3.0f));
						}
						else
						{
							SpectateCamera->SetActorRotation(FMath::RInterpTo(SpectateCamera->GetActorRotation(), It->GetCharacter()->GetActorRotation(), DeltaSeconds, 3.0f));
						}
					}
					else
					{
						ABaseMagazineWeapon* EquippedWeapon = Cast<ABaseMagazineWeapon>(It->GetCharacter()->GetEquippedItem());
						SpectateCamera->SetActorLocation(FMath::VInterpTo(SpectateCamera->GetActorLocation(), EquippedWeapon->GetBulletSpawn()->GetComponentLocation() + EquippedWeapon->GetBulletSpawn()->GetForwardVector() * -100.0f + FVector(0.0f, 0.0f, 0.0f), DeltaSeconds, 3.0f));
						SpectateCamera->SetActorRotation(FMath::RInterpTo(SpectateCamera->GetActorRotation(),  FRotator(EquippedWeapon->GetBulletSpawn()->GetComponentRotation().Pitch, EquippedWeapon->GetBulletSpawn()->GetComponentRotation().Yaw, 0.0f), DeltaSeconds, 3.0f));
					}
					
					break;
				}
			}
		}
	}
	#endif

	#if !UE_BUILD_SHIPPING
		#if PLATFORM_WINDOWS
		FString ClientServerStr = GetNetMode() == ENetMode::NM_Client ? "[Client] " : "[Server] " ;
		GEngine->AddOnScreenDebugMessage(10090, 1.0f, FColor::Yellow, ClientServerStr + "ProcessId: " + FString::FromInt(FWindowsPlatformProcess::GetCurrentProcessId()));
		#endif
	#endif

	if (bIsReplaySpectator && GetPlayerState<AReadyOrNotPlayerState>())
	{
		GetPlayerState<AReadyOrNotPlayerState>()->Destroy();
	}

	DebugGatherDebugActors();
	DebugDrawDebugActors(DeltaSeconds);

	UReadyOrNotGameInstance* gi = Cast<UReadyOrNotGameInstance>(GetWorld()->GetGameInstance());
	if (gi->bForceShowMouseCursor)
	{
		if (!(GetWorld()->GetDemoNetDriver() && GetWorld()->GetDemoNetDriver()->IsPlaying()))
		{
			SetShouldShowMouseCursor(gi->bForceShowMouseCursor);
		}
	}

	RespawnTimeLeft = FMath::Max(RespawnTimeLeft - DeltaSeconds, 0.0f);
	VoteAntiSpamDebouncerCurrent = FMath::Max(VoteAntiSpamDebouncerCurrent - DeltaSeconds, 0.0f);

	if (GetViewTarget() == this)
	{
		if (Cast<APlayerCharacter>(GetPawn()))
		{
			SetViewTarget(GetPawn());
		}
	}
	
	APlayerCharacter* pc = Cast<APlayerCharacter>(GetPawn());
	if (pc)
	{
		pc->ReplicatedControlRotation = GetControlRotation();
		pc->ReplicatedControlRotation.Pitch += pc->FreeLookCache.Pitch;
		pc->ReplicatedControlRotation.Yaw += pc->FreeLookCache.Yaw;

        AReadyOrNotPlayerState* ps = GetRoNPlayerState();
		if (ps)
		{
			if (!pc->IsDeadOrUnconscious())
			{
				ps->TimeAlive += DeltaSeconds;
			}
		}
	}

	#if !UE_BUILD_SHIPPING
	if (bDrawScopeAlignmentTrace)
	{
		pc = Cast<APlayerCharacter>(GetPawn());
		if (pc)
		{
			ABaseWeapon* bw = Cast<ABaseWeapon>(pc->GetEquippedItem());
			if (bw && bw->ScopeAttachment)
			{
				if (bw->ScopeAttachment->bUsePipRendering)
				{
					DrawDebugLine(GetWorld(), bw->ScopeAttachment->PipSceneCapture->GetComponentLocation(), bw->ScopeAttachment->PipSceneCapture->GetComponentLocation() + (bw->ScopeAttachment->PipSceneCapture->GetForwardVector() * 20000.0f), FColor::Red, false, -1.0f, 0.0f, 0.25f);
					DrawDebugLine(GetWorld(), bw->GetBulletSpawn()->GetComponentLocation(), bw->GetBulletSpawn()->GetComponentLocation() + (bw->GetBulletSpawn()->GetForwardVector() * 20000.0f), FColor::Green, false, -1.0f, 0.0f, 0.25f);
				}
			}
		}
	}
	#endif
}

void AReadyOrNotPlayerController::SetShouldShowMouseCursor(bool bShow)
{
	bShouldShowMouseCursor = bShow;
	UpdateMouseCursorVisibility();
}

bool AReadyOrNotPlayerController::IsConsoleTarget()
{
#if defined(TARGET_CONSOLE)
	return true;
#else
	return false;
#endif
}

void AReadyOrNotPlayerController::UpdateMouseCursorVisibility()
{
	bool bUsingGamepad = UReadyOrNotFunctionLibrary::IsUsingGamepad(this);
	
	bool bDoShow = bShouldShowMouseCursor && !bUsingGamepad;
	bShowMouseCursor = bDoShow;
	for (int i = 0; i < WidgetStack.Num(); ++i) {
		UUserWidget* Widget = UBpGameplayHelperLib::GetFirstWidgetFromViewport(WidgetStack[i]);
		if (Widget != nullptr)
			Widget->SetCursor(bDoShow ? EMouseCursor::Default : EMouseCursor::None);
	}
}

