void AReadyOrNotPlayerController::AddYaw(float Val)
{
	float sensitivity;
	UBpGameplayHelperLib::GetMouseSensitivity(sensitivity);
	DemoRecorderRotation.Yaw += (Val * sensitivity * 20.0f);
}

void AReadyOrNotPlayerController::AddPitch(float Val)
{
	float sensitivity;
	UBpGameplayHelperLib::GetMouseSensitivity(sensitivity);
	DemoRecorderRotation.Pitch -= (Val * sensitivity * 20.0f);
}

void AReadyOrNotPlayerController::MoveForward(float Val)
{
	DemoRecorderLocation += (Val * GetControlRotation().Vector()) * SpeedMultiplier;
}

void AReadyOrNotPlayerController::MoveRight(float Val)
{
	DemoRecorderLocation += (Val * UKismetMathLibrary::GetRightVector(GetControlRotation())) * SpeedMultiplier;
}

void AReadyOrNotPlayerController::AdjustSpeed(float Val)
{
	SpeedMultiplier = FMath::Clamp(SpeedMultiplier + Val, 0.01f, 100.0f);
}

