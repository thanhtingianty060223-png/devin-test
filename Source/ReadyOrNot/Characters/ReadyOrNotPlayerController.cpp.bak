void AReadyOrNotPlayerController::Server_StartReferendum_Implementation(TSubclassOf<class AReferendum> ReferendumClass)
{
	BeginVote_Implementation("Mission Soft Complete", "End The Mission?", false);
	BeginVote("Mission Soft Complete", "End The Mission?", false);

	for (TActorIterator<APlayerController> It(GetWorld()); It; ++It)
	{
		if (AReadyOrNotPlayerController* Controller = Cast<AReadyOrNotPlayerController>(*It))
		{
			if (Controller != this)
			{
				Controller->BeginVote_Implementation("Mission Soft Complete", "End The Mission?", false);
				Controller->BeginVote("Mission Soft Complete", "End The Mission?", false);
			}
		}
	}
}

void AReadyOrNotPlayerController::Server_StartMapReferendum_Implementation(TSubclassOf<class AMapReferendum> ReferendumClass, const FString& MapURL)
{
	AReadyOrNotGameState* gs = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (!gs)
	{
		return;
	}

	Server_StartReferendum_Implementation(ReferendumClass);

	AMapReferendum* MapReferendum = Cast<AMapReferendum>(gs->CurrentReferendum);
	if (!MapReferendum)
	{
		return;
	}

	MapReferendum->MapURL = MapURL;
}

void AReadyOrNotPlayerController::Server_StartPlayerReferendum_Implementation(TSubclassOf<class APlayerReferendum> ReferendumClass, class AReadyOrNotPlayerState* TargetPlayer)
{
	AReadyOrNotGameState* gs = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (!gs)
	{
		return;
	}

	Server_StartReferendum_Implementation(ReferendumClass);

	APlayerReferendum* PlayerReferendum = Cast<APlayerReferendum>(gs->CurrentReferendum);
	if (!PlayerReferendum)
	{
		return;
	}

	PlayerReferendum->TargetPlayerState = TargetPlayer;
}

void AReadyOrNotPlayerController::Server_ReferendumVoteYes_Implementation()
{
	AReadyOrNotGameState* gs = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (!gs)
	{
		return;
	}

	if (!gs->CurrentReferendum || !gs->CurrentReferendum->bReferendumRunning)
	{
		return; // there is no referendum running, we can't cast a vote for it
	}

	if (VoteAntiSpamDebouncerCurrent > 0.0f)
	{
		return; // no spamming votes allowed
	}

	VoteAntiSpamDebouncerCurrent = VoteAntiSpamDebouncer;
	gs->CurrentReferendum->CastedYesVote(this);
}

void AReadyOrNotPlayerController::Server_ReferendumVoteNo_Implementation()
{
	AReadyOrNotGameState* gs = GetWorld()->GetGameState<AReadyOrNotGameState>();
	if (!gs)
	{
		return;
	}

	if (!gs->CurrentReferendum || !gs->CurrentReferendum->bReferendumRunning)
	{
		return; // there is no referendum running, we can't cast a vote for it
	}

	if (VoteAntiSpamDebouncerCurrent > 0.0f)
	{
		return; // no spamming votes allowed
	}

	VoteAntiSpamDebouncerCurrent = VoteAntiSpamDebouncer;
	gs->CurrentReferendum->CastedNoVote(this);
}

void AReadyOrNotPlayerController::Server_AddMarker_Implementation(const FPlanningMarker& Marker)
{
	if (!GetWorld())
		return;

	AReadyOrNotGameMode* GameMode = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();
	if (!GameMode)
		return;
	
	AMissionPlanManager* MissionPlanManager = GameMode->MissionPlanManager;
	if (!MissionPlanManager)
		return;

	FPlanningMarker& AddedMark = MissionPlanManager->MarkerArray.Items.Add_GetRef(Marker);
	if (GetRoNPlayerState())
		AddedMark.PlayerNumber = GetRoNPlayerState()->PlanningPlayerNumber;
	
	MissionPlanManager->MarkerArray.MarkItemDirty(AddedMark);
	MissionPlanManager->MarkerArray.OnPlanningMarkerAdded.Broadcast(AddedMark);
}

void AReadyOrNotPlayerController::Server_RemoveMarker_Implementation(int32 ID)
{
	if (ID == INDEX_NONE)
		return;
	
	if (!GetWorld())
		return;

	AReadyOrNotGameMode* GameMode = GetWorld()->GetAuthGameMode<AReadyOrNotGameMode>();
	if (!GameMode)
		return;
	
	AMissionPlanManager* MissionPlanManager = GameMode->MissionPlanManager;
	if (!MissionPlanManager)
		return;

	AReadyOrNotPlayerState* ReadyOrNotPlayerState = GetRoNPlayerState();
	if (!ReadyOrNotPlayerState)
		return;
	
	int32 PlayerNumber = ReadyOrNotPlayerState->PlanningPlayerNumber;
	int32 Removed = MissionPlanManager->MarkerArray.Items.RemoveAll([ID, PlayerNumber](const FPlanningMarker& Marker)
	{
		return Marker.ReplicationID == ID && Marker.PlayerNumber == PlayerNumber;
	});

	if (Removed > 0)
	{
		MissionPlanManager->MarkerArray.MarkArrayDirty();
		MissionPlanManager->MarkerArray.OnPlanningMarkerRemoved.Broadcast(ID);
	}
}

