		AReadyOrNotGameState* gs = Cast<AReadyOrNotGameState>(GetWorld()->GetGameState());
		if (gs)
		{
			FKillFeedData kf;
			kf.Name = Victim->GetPlayerState()->GetPlayerName();
			kf.Type = EKillfeedType::KT_Arrest;
			gs->KillfeedData.Add(kf);
		}
	}
}

